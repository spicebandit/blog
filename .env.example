# ── 블로그 서비스 키 ──────────────────────────────────────
UNSPLASH_ACCESS_KEY=
PUBLIC_CUSDIS_APP_ID=

# ── Google AdSense ────────────────────────────────────────
# 퍼블리셔 ID: AdSense 대시보드 > 계정 > 계정 정보
PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX

# 광고 슬롯 ID: AdSense > 광고 > 광고 단위 생성 후 10자리 숫자
PUBLIC_ADSENSE_SLOT_HEADER=          # 헤더 배너 (반응형)
PUBLIC_ADSENSE_SLOT_IN_ARTICLE=      # 인아티클 (fluid)
PUBLIC_ADSENSE_SLOT_BOTTOM=          # 기사 하단 (반응형)
PUBLIC_ADSENSE_SLOT_SIDEBAR=         # 사이드바 (160×600, 미구현)

# ── Kakao AdFit (AdSense 미설정 시 대체) ──────────────────
# AdFit 대시보드 > 광고 단위 생성 후 DAN-XXXXXXXXXX 코드 사용
PUBLIC_ADFIT_UNIT_HEADER=            # PC 헤더 (728×90)
PUBLIC_ADFIT_UNIT_HEADER_M=          # 모바일 헤더 (320×100)
PUBLIC_ADFIT_UNIT_IN_ARTICLE=        # 인아티클 (320×100)
PUBLIC_ADFIT_UNIT_BOTTOM=            # 기사 하단 (300×250)

# ── Telegram (daily-stats 알림) ───────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Google Analytics 4 ───────────────────────────────────
GA4_PROPERTY_ID=
GA_SA_KEY_FILE=
