---
import Analytics from '@vercel/analytics/astro';
import { CATEGORY_SLUGS, CATEGORY_NAMES } from '../lib/categories';
interface Props {
  title: string;
  description: string;
  type?: string;
  pubDate?: Date;
  updatedDate?: Date;
}
const { title, description, type = 'website', pubDate, updatedDate } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const SITE_NAME = '세상은 니가 구해라'; // TODO: 블로그 이름 변경

const pathname = Astro.url.pathname;
// 네비게이션 항목: 전체(홈) + 4개 카테고리
const navItems = [
  { href: '/', label: '전체' },
  ...CATEGORY_SLUGS.map((slug) => ({ href: `/category/${slug}/`, label: CATEGORY_NAMES[slug] })),
];
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname === href.replace(/\/$/, '');

// 상단 공지(핀) — 모든 페이지의 카테고리 메뉴 아래에 노출.
// until 이후에는 빌드 시 자동으로 사라진다. 월드컵 종료(7/21)에 맞춰 정리.
const NOTICE = {
  href: '/blog/2026-world-cup-tracker/',
  emoji: '⚽',
  label: '2026 북중미 월드컵 한눈에 보기',
  badge: '매일 갱신',
  until: new Date('2026-07-21T00:00:00+09:00'),
};
const showNotice = new Date() < NOTICE.until;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- 다크모드: 본문 렌더 전에 테마를 먼저 정해 깜빡임(FOUC) 방지 -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'dark' && t !== 'light') {
            t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
    <title>{title === SITE_NAME ? title : `${title} | ${SITE_NAME}`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE_NAME} href="/rss.xml" />

    <!-- TODO: 서치콘솔/서치어드바이저 등록 시 발급받은 코드로 교체 -->
    <meta name="google-site-verification" content="9CN_w6tkNr_y8h6bhS5zyXZtWi9HnmRwhUNbk3_4foA" />
    <meta name="naver-site-verification" content="2304962573c68823df2550048d161b1d87227173" />

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />

    {pubDate && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        datePublished: pubDate.toISOString(),
        dateModified: (updatedDate ?? pubDate).toISOString(),
        url: canonical.toString(),
      })} />
    )}

    <style is:global>
      :root {
        --ink: #221c2e;
        --muted: #6d6580;
        --accent: #7a3ff2;
        --accent-soft: #efe8ff;
        --line: #e8e4f0;
        --bg: #ffffff;
        --notice-grad-end: #fbf9ff;
      }
      [data-theme="dark"] {
        --ink: #ece8f4;
        --muted: #a59cb8;
        --accent: #a98bf6;
        --accent-soft: #2a2440;
        --line: #322b44;
        --bg: #15121d;
        --notice-grad-end: #1c1730;
        color-scheme: dark;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: 'Pretendard Variable', Pretendard, -apple-system, 'Apple SD Gothic Neo',
          'Noto Sans KR', system-ui, sans-serif;
        line-height: 1.75;
        font-size: 17px;
        -webkit-font-smoothing: antialiased;
      }
      .wrap { max-width: 680px; margin: 0 auto; padding: 0 20px; }
      header.site {
        border-bottom: 1px solid var(--line);
        padding: 28px 0;
        margin-bottom: 48px;
      }
      header.site a.logo {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 800;
        font-size: 1.3rem;
        letter-spacing: -0.02em;
        color: var(--ink);
        text-decoration: none;
      }
      header.site a.logo:hover { text-decoration: none; }
      /* 로고 + 다크모드 토글 한 줄 */
      header.site .top-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }
      .theme-toggle {
        flex: none;
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: 1px solid var(--line);
        border-radius: 999px;
        color: var(--muted);
        cursor: pointer;
        transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
      }
      .theme-toggle:hover {
        color: var(--accent);
        border-color: var(--accent);
        background: var(--accent-soft);
      }
      .theme-toggle .icon-sun { display: none; }
      [data-theme="dark"] .theme-toggle .icon-moon { display: none; }
      [data-theme="dark"] .theme-toggle .icon-sun { display: inline-flex; }
      header.site a.logo .mascot {
        width: 34px;
        height: 34px;
        flex: none;
        transform-origin: 50% 80%;
        transition: transform 0.25s ease;
      }
      header.site a.logo:hover .mascot {
        animation: mascot-wiggle 0.6s ease-in-out;
      }
      @keyframes mascot-wiggle {
        0%, 100% { transform: rotate(0deg); }
        25% { transform: rotate(-9deg); }
        75% { transform: rotate(9deg); }
      }
      @media (prefers-reduced-motion: reduce) {
        header.site a.logo:hover .mascot { animation: none; }
      }
      /* 카테고리 네비게이션 */
      header.site nav.cats {
        display: flex;
        flex-wrap: wrap;
        gap: 6px 8px;
        margin-top: 16px;
      }
      header.site nav.cats .cat-link {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.92rem;
        font-weight: 600;
        line-height: 1.2;
        padding: 5px 11px;
        border: 1px solid var(--line);
        border-radius: 999px;
        white-space: nowrap;
        transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
      }
      header.site nav.cats .cat-link:hover {
        text-decoration: none;
        color: var(--accent);
        border-color: var(--accent);
        background: var(--accent-soft);
      }
      header.site nav.cats .cat-link.active {
        color: #fff;
        background: var(--accent);
        border-color: var(--accent);
      }
      /* 상단 공지(핀) 바 */
      header.site a.notice {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 14px;
        padding: 11px 14px;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: linear-gradient(180deg, var(--accent-soft), var(--notice-grad-end));
        color: var(--ink);
        text-decoration: none;
        font-size: 0.93rem;
        font-weight: 600;
        line-height: 1.3;
        transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
      }
      header.site a.notice:hover {
        text-decoration: none;
        border-color: var(--accent);
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(122, 63, 242, 0.13);
      }
      header.site a.notice .notice-tag {
        flex: none;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.02em;
        padding: 3px 9px;
        border-radius: 999px;
        background: var(--accent);
        color: #fff;
      }
      header.site a.notice .notice-title {
        flex: 1 1 auto;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      header.site a.notice .notice-badge {
        flex: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.76rem;
        font-weight: 700;
        color: var(--accent);
      }
      header.site a.notice .notice-badge .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #e0392b;
        box-shadow: 0 0 0 0 rgba(224, 57, 43, 0.55);
        animation: notice-pulse 1.8s ease-out infinite;
      }
      @keyframes notice-pulse {
        0% { box-shadow: 0 0 0 0 rgba(224, 57, 43, 0.55); }
        70% { box-shadow: 0 0 0 6px rgba(224, 57, 43, 0); }
        100% { box-shadow: 0 0 0 0 rgba(224, 57, 43, 0); }
      }
      @media (max-width: 420px) {
        header.site a.notice .notice-badge-text { display: none; }
      }
      @media (prefers-reduced-motion: reduce) {
        header.site a.notice .notice-badge .dot { animation: none; }
      }
      /* 글 목록·상세에서 쓰는 작은 카테고리 칩 */
      .cat-chip {
        display: inline-block;
        font-size: 0.78rem;
        font-weight: 700;
        line-height: 1;
        padding: 4px 9px;
        border-radius: 999px;
        color: var(--accent);
        background: var(--accent-soft);
        text-decoration: none;
      }
      .cat-chip:hover { text-decoration: none; background: var(--accent); color: #fff; }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; text-underline-offset: 3px; }
      h1, h2, h3 { letter-spacing: -0.025em; line-height: 1.35; }
      article h2 {
        margin-top: 2.2em;
        padding-left: 14px;
        border-left: 4px solid var(--accent);
      }
      article img { max-width: 100%; border-radius: 8px; }
      article code {
        background: var(--accent-soft);
        padding: 0.15em 0.4em;
        border-radius: 4px;
        font-size: 0.88em;
      }
      article pre { padding: 16px; border-radius: 10px; overflow-x: auto; font-size: 0.85em; }
      article pre code { background: none; padding: 0; }
      article blockquote {
        margin: 1.5em 0;
        padding: 4px 18px;
        border-left: 4px solid var(--line);
        color: var(--muted);
      }
      footer.site {
        border-top: 1px solid var(--line);
        margin-top: 80px;
        padding: 32px 0 48px;
        color: var(--muted);
        font-size: 0.85rem;
      }
      time, .meta { color: var(--muted); font-size: 0.85rem; }
      :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
      @media (prefers-reduced-motion: reduce) { * { transition: none !important; } }
    </style>
    <link rel="stylesheet" as="style" crossorigin
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />

    <!-- Google Analytics 4 (측정 ID는 공개값) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-KM0XNWHRCM"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-KM0XNWHRCM');
    </script>
  </head>
  <body>
    <header class="site">
      <div class="wrap">
        <div class="top-row">
        <a class="logo" href="/">
          <span>세상은 니가 구해라</span>
          <svg class="mascot" viewBox="0 0 64 64" role="img" aria-label="Spice Bandit 해적 마스코트">
            <!-- 얼굴 -->
            <circle cx="32" cy="35" r="18" fill="#f4c89f" stroke="#e0a878" stroke-width="1.4"/>
            <!-- 금 귀걸이 -->
            <circle cx="14.5" cy="42" r="3" fill="none" stroke="#e8b53a" stroke-width="2"/>
            <!-- 반다나(두건) -->
            <path d="M13 27 Q32 11 51 27 Q32 20 13 27 Z" fill="#d6473f"/>
            <path d="M13 27 Q32 20 51 27 L51 31 Q32 25 13 31 Z" fill="#c33b34"/>
            <!-- 반다나 매듭 + 꼬리 -->
            <path d="M50 27 l7 -3 -2 6 z" fill="#c33b34"/>
            <path d="M55 26 q8 2 9 9 q-6 -3 -10 -2 z" fill="#d6473f"/>
            <!-- 반다나 물방울무늬 -->
            <circle cx="24" cy="24" r="1.4" fill="#f6d3cf"/>
            <circle cx="33" cy="21.5" r="1.4" fill="#f6d3cf"/>
            <circle cx="42" cy="24" r="1.4" fill="#f6d3cf"/>
            <!-- 눈가리개 끈 -->
            <path d="M18 30 L46 26" stroke="#3a322e" stroke-width="1.6"/>
            <!-- 눈가리개(왼눈) -->
            <ellipse cx="24" cy="34" rx="5" ry="5.4" fill="#3a322e"/>
            <!-- 뜬 눈(오른눈) -->
            <circle cx="40" cy="34" r="2.7" fill="#3a322e"/>
            <circle cx="41" cy="33" r="0.9" fill="#fff"/>
            <!-- 웃는 입 -->
            <path d="M28 43 q5 5 11 1" stroke="#7a4a32" stroke-width="1.8" fill="none" stroke-linecap="round"/>
          </svg>
        </a>
        <button class="theme-toggle" type="button" aria-label="다크 모드 전환" title="다크 모드 전환">
          <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/>
          </svg>
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"/>
          </svg>
        </button>
        </div>
        <nav class="cats" aria-label="카테고리">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={['cat-link', { active: isActive(item.href) }]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
        {showNotice && (
          <a class="notice" href={NOTICE.href} aria-label={`공지: ${NOTICE.label}`}>
            <span class="notice-tag">공지</span>
            <span class="notice-title">{NOTICE.emoji} {NOTICE.label}</span>
            <span class="notice-badge"><span class="dot" aria-hidden="true"></span><span class="notice-badge-text">{NOTICE.badge}</span></span>
          </a>
        )}
      </div>
    </header>
    <main class="wrap">
      <slot />
    </main>
    <footer class="site">
      <div class="wrap">
        © {new Date().getFullYear()} Spice Bandit · <a href="/rss.xml">RSS</a>
      </div>
    </footer>
    <Analytics />
    <script is:inline>
      (function () {
        var btn = document.querySelector('.theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', function () {
          var cur = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
          var next = cur === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          try { localStorage.setItem('theme', next); } catch (e) {}
        });
      })();
    </script>
  </body>
</html>
