---
import Analytics from '@vercel/analytics/astro';
import { CATEGORY_SLUGS, CATEGORY_NAMES } from '../lib/categories';

const ADSENSE_PUB = import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID ?? '';
const ADFIT_ENABLED =
  !!(import.meta.env.PUBLIC_ADFIT_UNIT_HEADER     ||
     import.meta.env.PUBLIC_ADFIT_UNIT_HEADER_M   ||
     import.meta.env.PUBLIC_ADFIT_UNIT_IN_ARTICLE ||
     import.meta.env.PUBLIC_ADFIT_UNIT_BOTTOM);
const adsenseSrc = ADSENSE_PUB
  ? `https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_PUB}`
  : '';

interface HrefLangAlt {
  lang: string; // e.g. 'ko', 'en'
  href: string; // absolute URL
}

interface Props {
  title: string;
  description: string;
  type?: string;
  pubDate?: Date;
  updatedDate?: Date;
  wide?: boolean;
  lang?: string; // page language, defaults to 'ko'
  hrefLangAlts?: HrefLangAlt[]; // hreflang alternate links
}

const { title, description, type = 'website', pubDate, updatedDate, wide = false, lang = 'ko', hrefLangAlts } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const SITE_NAME = 'BASELOAD';

const pathname = Astro.url.pathname;
const navItems = [
  { href: '/', label: '전체', cat: null as string | null },
  ...CATEGORY_SLUGS.map((slug) => ({ href: `/category/${slug}/`, label: CATEGORY_NAMES[slug], cat: slug })),
];
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname === href.replace(/\/$/, '');

// 상단바 날짜 (빌드 시점 KST — 정적 사이트라 배포 시각 기준)
const todayLabel = new Intl.DateTimeFormat(lang === 'en' ? 'en-US' : 'ko-KR', {
  timeZone: 'Asia/Seoul', year: 'numeric', month: 'long', day: 'numeric', weekday: 'short',
}).format(new Date());

---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'dark' && t !== 'light') {
            t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
    <title>{title === SITE_NAME ? title : `${title} | ${SITE_NAME}`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {hrefLangAlts && hrefLangAlts.map((alt) => (
      <link rel="alternate" hreflang={alt.lang} href={alt.href} />
    ))}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE_NAME} href="/rss.xml" />

    <meta name="google-site-verification" content="9CN_w6tkNr_y8h6bhS5zyXZtWi9HnmRwhUNbk3_4foA" />
    <meta name="naver-site-verification" content="2304962573c68823df2550048d161b1d87227173" />

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'ko_KR'} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />

    {pubDate && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        datePublished: pubDate.toISOString(),
        dateModified: (updatedDate ?? pubDate).toISOString(),
        url: canonical.toString(),
      })} />
    )}

    <style is:global>
      /* ── DESIGN TOKENS (C안: 프리미엄 신문형) ── */
      :root {
        /* Brand — 레드 단일 액센트 */
        --accent:       #C8102E;
        --accent-soft:  #F6E3DC;
        --accent-dark:  #9C0C24;

        /* Semantic — 크림 지면 + 잉크 */
        --ink:     #23201D;
        --ink-2:   #45403A;
        --muted:   #6B635B;
        --line:    #E7D8C8;
        --line-2:  #EFE5D6;
        --bg:      #F1EADD;
        --bg-2:    #FAF6EC;
        --ad-bg:   #EFE5D6;

        /* Notice gradient */
        --notice-grad-end: #FAF6EC;

        /* Category colors — 단일 레드로 통일 (기존 4색 폐지) */
        --cat-energy:        var(--accent);
        --cat-economy:       var(--accent);
        --cat-ai:            var(--accent);
        --cat-life:          var(--accent);
        --cat-energy-soft:   var(--accent-soft);
        --cat-economy-soft:  var(--accent-soft);
        --cat-ai-soft:       var(--accent-soft);
        --cat-life-soft:     var(--accent-soft);

        /* Typography */
        --font-serif: 'Source Serif 4', 'Noto Serif KR', 'Apple SD Gothic Neo', serif;
        --font-ui: 'Pretendard Variable', Pretendard, -apple-system, 'Apple SD Gothic Neo',
          'Noto Sans KR', system-ui, sans-serif;

        /* Layout — 신문형: 모서리 각지게, 그림자 절제 */
        --max-w:      1200px;
        --nav-h:      56px;
        --radius-sm:  2px;
        --radius-md:  3px;
        --radius-lg:  4px;
        --radius-xl:  4px;
        --shadow-sm:  0 1px 2px rgba(35,32,29,.06);
        --shadow-md:  0 2px 8px rgba(35,32,29,.08);
        --shadow-lg:  0 6px 24px rgba(35,32,29,.10);
      }

      [data-theme="dark"] {
        --accent:      #E6485F;
        --accent-soft: #3A2226;
        --accent-dark: #F27187;

        --ink:    #EFE9DE;
        --ink-2:  #CFC7B9;
        --muted:  #A89F93;
        --line:   #3A342C;
        --line-2: #2B2620;
        --bg:     #191613;
        --bg-2:   #211D19;
        --ad-bg:  #211D19;

        --notice-grad-end: #211D19;

        color-scheme: dark;
      }

      /* ── RESET ─────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--font-ui);
        line-height: 1.75;
        font-size: 17px;
        -webkit-font-smoothing: antialiased;
      }

      /* Skip link */
      .skip-link {
        position: absolute; top: -9999px; left: 8px;
        background: var(--accent); color: #fff;
        padding: 6px 12px; border-radius: 4px;
        font-size: 0.8125rem; font-weight: 700;
        z-index: 9999;
      }
      .skip-link:focus { top: 8px; }

      /* ── WRAP ──────────────────────────────── */
      .wrap {
        max-width: 680px;
        margin: 0 auto;
        padding: 0 20px;
      }
      .wrap.wide {
        max-width: 1200px;
        padding: 0 24px;
      }

      /* ── NEWSPAPER HEADER (C안 / 2c) ───────── */
      /* ① 검은 상단바: 날짜 · 유틸(테마/언어/RSS) */
      .topbar {
        background: var(--ink);
        color: var(--bg);
      }
      .topbar-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 7px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }
      .topbar-date {
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        color: var(--bg);
      }
      .topbar-actions {
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .topbar-actions a,
      .topbar-actions button {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: none;
        border: none;
        padding: 0;
        font-family: var(--font-ui);
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        color: var(--bg);
        opacity: 0.85;
        cursor: pointer;
        text-decoration: none;
        transition: opacity .15s;
      }
      .topbar-actions a:hover,
      .topbar-actions button:hover { opacity: 1; text-decoration: none; }
      .topbar .icon-sun { display: none; }
      [data-theme="dark"] .topbar .icon-moon { display: none; }
      [data-theme="dark"] .topbar .icon-sun { display: inline-flex; }

      /* ② 마스트헤드 행: 로고 + 카테고리 내비 + 태그라인, 아래 이중괘선 */
      .masthead {
        background: var(--bg);
        border-bottom: 3px double var(--ink);
      }
      .masthead-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 14px 24px;
        display: flex;
        align-items: center;
        gap: 28px;
      }
      .nav-logo {
        flex: none;
        font-family: var(--font-serif);
        font-size: 1.875rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        line-height: 1;
        color: var(--ink);
        text-decoration: none;
      }
      .nav-logo:hover { text-decoration: none; color: var(--ink); }

      .nav-cats { min-width: 0; }
      .nav-cats ul {
        display: flex;
        gap: 2px;
        list-style: none;
        padding: 0; margin: 0;
        overflow-x: auto;
        scrollbar-width: none;
      }
      .nav-cats ul::-webkit-scrollbar { display: none; }
      .nav-cats a {
        display: block;
        padding: 8px 15px;
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--ink);
        transition: color .15s, background .15s;
        white-space: nowrap;
        text-decoration: none;
      }
      .nav-cats a:hover { color: var(--accent); text-decoration: none; }
      .nav-cats a.active {
        color: #F1EADD;
        background: var(--accent);
        font-weight: 600;
      }
      .nav-cats a.active:hover { color: #F1EADD; }

      .masthead-tagline {
        flex: 1;
        text-align: right;
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        color: var(--muted);
        white-space: nowrap;
      }

      /* ── MAIN CONTENT ──────────────────────── */
      main.wrap,
      main.wrap.wide {
        padding-top: 28px;
      }

      /* ── CATEGORY CHIP — 신문형 레드 캡스 라벨 ── */
      .cat-chip {
        display: inline-block;
        font-family: var(--font-ui);
        font-size: 0.72rem; font-weight: 700; line-height: 1;
        letter-spacing: 0.12em; text-transform: uppercase;
        color: var(--accent);
        text-decoration: none;
      }
      .cat-chip:hover { text-decoration: underline; text-underline-offset: 3px; }

      /* ── GLOBAL LINKS / HEADINGS ───────────── */
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; text-underline-offset: 3px; }
      h1, h2, h3 {
        font-family: var(--font-serif);
        letter-spacing: -0.015em;
        line-height: 1.3;
      }

      /* ── ARTICLE PAGE STYLES ───────────────── */
      article {
        font-family: var(--font-serif);
      }
      article h2 {
        margin-top: 2.2em;
        padding-bottom: 8px;
        border-bottom: 2px solid var(--ink);
      }
      article img { max-width: 100%; border-radius: 8px; }
      article code {
        background: var(--accent-soft);
        padding: 0.15em 0.4em;
        border-radius: 4px;
        font-size: 0.88em;
      }
      article pre { padding: 16px; border-radius: 10px; overflow-x: auto; font-size: 0.85em; }
      article pre code { background: none; padding: 0; }
      /* 표: 화면보다 넓으면 페이지 전체가 아니라 표 안에서만 좌우 스크롤 (모바일 가로 넘침 방지) */
      article table {
        display: block;
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        border-collapse: collapse;
        margin: 1.2em 0;
        font-size: 0.85em;
        font-family: var(--font-ui); /* 데이터 표는 산세리프 유지 */
      }
      article th, article td {
        border: 1px solid var(--line);
        padding: 8px 10px;
        text-align: left;
        vertical-align: top;
        overflow-wrap: anywhere;
        word-break: keep-all;
      }
      article thead th { background: var(--accent-soft); font-weight: 700; }
      article blockquote {
        margin: 1.5em 0;
        padding: 4px 18px;
        border-left: 4px solid var(--line);
        color: var(--muted);
      }

      /* ── FOOTER (Apple-inspired) ───────────── */
      footer.site {
        background: var(--bg-2);          /* Apple canvas-parchment */
        border-top: 1px solid var(--line);
        margin-top: 0;
        padding: 48px 0 56px;             /* Apple footer: 64px — 실용 버전 */
        color: var(--muted);
        font-size: 0.75rem;               /* Apple fine-print: 12px */
        letter-spacing: -0.12px;          /* Apple fine-print tracking */
        line-height: 2.0;                 /* Apple dense-link: 2.41 — 링크 열 가독성 */
      }
      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0 24px;
        margin-bottom: 10px;
      }
      .footer-links a {
        color: var(--ink-2);
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: -0.12px;
        text-decoration: none;
        transition: color .15s;
      }
      .footer-links a:hover {
        color: var(--accent);
        text-decoration: none;
      }
      .footer-legal {
        margin: 0;
        color: var(--muted);
      }

      time, .meta { color: var(--muted); font-size: 0.85rem; }

      /* ④ 맨위로 버튼 */
      .to-top {
        position: fixed;
        right: 20px;
        bottom: 24px;
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg);
        color: var(--ink);
        border: 1px solid var(--ink);
        border-radius: 50%;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
        z-index: 90;
        transition: color .15s, border-color .15s, transform .15s;
      }
      .to-top:hover {
        color: var(--accent);
        border-color: var(--accent);
        transform: translateY(-2px);
      }
      .to-top[hidden] { display: none; }

      :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; border-radius: 2px; }

      @media (prefers-reduced-motion: reduce) {
        * { transition: none !important; animation: none !important; }
      }

      /* ── RESPONSIVE HEADER ──────────────────── */
      @media (max-width: 767px) {
        .topbar-inner { padding: 6px 16px; }
        .masthead-inner {
          flex-wrap: wrap;
          gap: 0;
          padding: 12px 16px 0;
          justify-content: center;
        }
        .nav-logo {
          font-size: 1.5rem;
          width: 100%;
          text-align: center;
          padding-bottom: 10px;
        }
        .nav-cats { width: 100%; border-top: 1px solid var(--line); }
        .nav-cats ul { justify-content: center; }
        .nav-cats a { padding: 9px 13px; font-size: 0.8rem; }
        .masthead-tagline { display: none; }
      }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&family=Noto+Serif+KR:wght@400;600;700&display=swap" />
    <link rel="stylesheet" as="style" crossorigin
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />

    {/* Google AdSense */}
    {adsenseSrc && (
      <script is:inline async src={adsenseSrc} crossorigin="anonymous"></script>
    )}
    {/* Kakao AdFit */}
    {ADFIT_ENABLED && (
      <script is:inline async src="//t1.daumcdn.net/kas/static/ba.min.js"></script>
    )}

    <script is:inline>
      (function () {
        try {
          var p = new URLSearchParams(location.search);
          if (p.has('me')) {
            if (p.get('me') === 'off') {
              localStorage.removeItem('ga_exclude_owner');
            } else {
              localStorage.setItem('ga_exclude_owner', '1');
            }
          }
          window.__gaExcludeOwner = localStorage.getItem('ga_exclude_owner') === '1';
        } catch (e) {
          window.__gaExcludeOwner = false;
        }
      })();
    </script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-KM0XNWHRCM"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      // 프로덕션 도메인(www.baseload.co.kr)에서만 GA4 활성화
      // localhost, Vercel 프리뷰 URL, 구 도메인 트래픽 차단
      var __gaAllowed = location.hostname === 'www.baseload.co.kr';
      if (!__gaAllowed || window.__gaExcludeOwner) {
        window['ga-disable-G-KM0XNWHRCM'] = true;
      } else {
        gtag('config', 'G-KM0XNWHRCM', {
          language_version: location.pathname.startsWith('/en/') ? 'en' : 'ko'
        });
      }
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">콘텐츠로 건너뛰기</a>

    <!-- ── NEWSPAPER HEADER (검은 상단바 + 마스트헤드) ── -->
    <div class="topbar">
      <div class="topbar-inner">
        <span class="topbar-date">{todayLabel}</span>
        <div class="topbar-actions">
          {lang === 'en' ? (
            <a href="/" aria-label="한국어로 전환">한국어</a>
          ) : (
            <a href="/en/" aria-label="Switch to English">EN</a>
          )}
          <button class="theme-toggle" type="button" aria-label="다크 모드 전환">
            <svg class="icon-moon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/>
            </svg>
            <svg class="icon-sun" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4"/>
              <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"/>
            </svg>
          </button>
          <a href="/rss.xml" aria-label={lang === 'en' ? 'RSS feed' : 'RSS 구독'}>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/>
              <circle cx="5" cy="19" r="1" fill="currentColor"/>
            </svg>
            {lang === 'en' ? 'RSS' : 'RSS 구독'}
          </a>
        </div>
      </div>
    </div>
    <header class="masthead">
      <div class="masthead-inner">
        <a class="nav-logo" href={lang === 'en' ? '/en/' : '/'}>BASELOAD</a>
        {lang !== 'en' && (
          <nav class="nav-cats" role="navigation" aria-label="카테고리">
            <ul role="list">
              {navItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class:list={[{ active: isActive(item.href) }]}
                    aria-current={isActive(item.href) ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )}
        <span class="masthead-tagline">
          {lang === 'en' ? 'AI & Agentic Intelligence — English Edition' : '에너지 · 경제 · AI 심층 리포트'}
        </span>
      </div>
    </header>

    <!-- ── MAIN CONTENT ────────────────────────── -->
    <main id="main" class:list={['wrap', { wide }]}>
      <slot />
    </main>

    <footer class="site">
      <div class="wrap">
        <div class="footer-links">
          <a href="/category/energy/">에너지</a>
          <a href="/category/economy/">경제·경영</a>
          <a href="/category/ai/">AI·AX</a>
          <a href="/category/life/">Editor</a>
          <a href="/rss.xml">RSS</a>
          <a href="/privacy/">개인정보처리방침</a>
        </div>
        <p class="footer-legal">© {new Date().getFullYear()} BASELOAD</p>
      </div>
    </footer>

    <!-- ④ 맨위로 버튼: 600px 이상 스크롤 시 우하단에 노출 -->
    <button class="to-top" type="button" aria-label="맨 위로" hidden>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 19V5M5 12l7-7 7 7"/>
      </svg>
    </button>

    <Analytics />

    <script is:inline>
      (function () {
        var top = document.querySelector('.to-top');
        if (top) {
          var onScroll = function () { top.hidden = window.scrollY < 600; };
          onScroll();
          window.addEventListener('scroll', onScroll, { passive: true });
          top.addEventListener('click', function () {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }
      })();
    </script>

    <script is:inline>
      (function () {
        var btn = document.querySelector('.theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', function () {
          var cur = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
          var next = cur === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          try { localStorage.setItem('theme', next); } catch (e) {}
        });
      })();
    </script>
  </body>
</html>
