---
import Analytics from '@vercel/analytics/astro';
import { CATEGORY_SLUGS, CATEGORY_NAMES } from '../lib/categories';

const ADSENSE_PUB = import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID ?? '';
const ADFIT_ENABLED =
  !!(import.meta.env.PUBLIC_ADFIT_UNIT_HEADER     ||
     import.meta.env.PUBLIC_ADFIT_UNIT_HEADER_M   ||
     import.meta.env.PUBLIC_ADFIT_UNIT_IN_ARTICLE ||
     import.meta.env.PUBLIC_ADFIT_UNIT_BOTTOM);
const adsenseSrc = ADSENSE_PUB
  ? `https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_PUB}`
  : '';

interface HrefLangAlt {
  lang: string; // e.g. 'ko', 'en'
  href: string; // absolute URL
}

interface Props {
  title: string;
  description: string;
  type?: string;
  pubDate?: Date;
  updatedDate?: Date;
  wide?: boolean;
  lang?: string; // page language, defaults to 'ko'
  hrefLangAlts?: HrefLangAlt[]; // hreflang alternate links
}

const { title, description, type = 'website', pubDate, updatedDate, wide = false, lang = 'ko', hrefLangAlts } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const SITE_NAME = 'BASELOAD';

const pathname = Astro.url.pathname;
const navItems = [
  { href: '/', label: '전체', cat: null as string | null },
  ...CATEGORY_SLUGS.map((slug) => ({ href: `/category/${slug}/`, label: CATEGORY_NAMES[slug], cat: slug })),
];
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname === href.replace(/\/$/, '');

const NOTICE = {
  href: '/blog/2026-world-cup-tracker/',
  emoji: '⚽',
  label: '2026 북중미 월드컵 한눈에 보기',
  badge: '매일 갱신',
  until: new Date('2026-07-21T00:00:00+09:00'),
};
const showNotice = new Date() < NOTICE.until;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'dark' && t !== 'light') {
            t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
    <title>{title === SITE_NAME ? title : `${title} | ${SITE_NAME}`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {hrefLangAlts && hrefLangAlts.map((alt) => (
      <link rel="alternate" hreflang={alt.lang} href={alt.href} />
    ))}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE_NAME} href="/rss.xml" />

    <meta name="google-site-verification" content="9CN_w6tkNr_y8h6bhS5zyXZtWi9HnmRwhUNbk3_4foA" />
    <meta name="naver-site-verification" content="2304962573c68823df2550048d161b1d87227173" />

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />

    {pubDate && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        datePublished: pubDate.toISOString(),
        dateModified: (updatedDate ?? pubDate).toISOString(),
        url: canonical.toString(),
      })} />
    )}

    <style is:global>
      /* ── DESIGN TOKENS ─────────────────────── */
      :root {
        /* Brand */
        --accent:       #7a3ff2;
        --accent-soft:  #efe8ff;
        --accent-dark:  #5a2ec0;

        /* Semantic */
        --ink:     #221c2e;
        --ink-2:   #374151;
        --muted:   #6d6580;
        --line:    #e8e4f0;
        --line-2:  #f3f4f6;
        --bg:      #ffffff;
        --bg-2:    #f9fafb;
        --ad-bg:   #f3f4f6;

        /* Notice gradient */
        --notice-grad-end: #fbf9ff;

        /* Category colors */
        --cat-energy:        #d97706;
        --cat-economy:       #059669;
        --cat-ai:            #7a3ff2;
        --cat-life:          #db2777;
        --cat-energy-soft:   #fef3c7;
        --cat-economy-soft:  #d1fae5;
        --cat-ai-soft:       #ede9fe;
        --cat-life-soft:     #fce7f3;

        /* Layout */
        --max-w:      1200px;
        --nav-h:      56px;
        --radius-sm:  6px;
        --radius-md:  10px;
        --radius-lg:  14px;
        --radius-xl:  18px;
        --shadow-sm:  0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.04);
        --shadow-md:  0 4px 16px rgba(0,0,0,.10), 0 2px 4px rgba(0,0,0,.06);
        --shadow-lg:  0 10px 40px rgba(0,0,0,.12), 0 4px 8px rgba(0,0,0,.06);
      }

      [data-theme="dark"] {
        --accent:      #a98bf6;
        --accent-soft: #2a2440;
        --accent-dark: #c3a8ff;

        --ink:    #ece8f4;
        --ink-2:  #c9c5d8;
        --muted:  #a59cb8;
        --line:   #322b44;
        --line-2: #1e1c2a;
        --bg:     #15121d;
        --bg-2:   #1c1730;
        --ad-bg:  #1a1826;

        --notice-grad-end: #1c1730;

        --cat-energy:        #fbbf24;
        --cat-economy:       #34d399;
        --cat-ai:            #a68bf5;
        --cat-life:          #f472b6;
        --cat-energy-soft:   #292214;
        --cat-economy-soft:  #0d2218;
        --cat-ai-soft:       #1e1830;
        --cat-life-soft:     #2a1220;

        color-scheme: dark;
      }

      /* ── RESET ─────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: 'Pretendard Variable', Pretendard, -apple-system, 'Apple SD Gothic Neo',
          'Noto Sans KR', system-ui, sans-serif;
        line-height: 1.75;
        font-size: 17px;
        -webkit-font-smoothing: antialiased;
      }

      /* Skip link */
      .skip-link {
        position: absolute; top: -9999px; left: 8px;
        background: var(--accent); color: #fff;
        padding: 6px 12px; border-radius: 4px;
        font-size: 0.8125rem; font-weight: 700;
        z-index: 9999;
      }
      .skip-link:focus { top: 8px; }

      /* ── WRAP ──────────────────────────────── */
      .wrap {
        max-width: 680px;
        margin: 0 auto;
        padding: 0 20px;
      }
      .wrap.wide {
        max-width: 1200px;
        padding: 0 24px;
      }

      /* ── STICKY NAV ────────────────────────── */
      .site-nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--line);
        height: var(--nav-h);
      }
      [data-theme="dark"] .site-nav {
        background: rgba(21,18,29,0.92);
      }
      .nav-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 0 24px;
        height: 100%;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .nav-logo {
        font-size: 0.9375rem;
        font-weight: 900;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        color: var(--ink);
        flex: none;
        display: flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
        margin-right: 8px;
        transition: color .15s;
      }
      .nav-logo:hover { text-decoration: none; color: var(--accent); }
      .logo-bolt {
        width: 18px; height: 18px; flex: none;
        color: var(--accent);
        transition: transform .2s;
      }
      .nav-logo:hover .logo-bolt { transform: scale(1.15); }

      .nav-cats {
        flex: 1;
        min-width: 0;
      }
      .nav-cats ul {
        display: flex;
        gap: 2px;
        list-style: none;
        padding: 0; margin: 0;
        overflow-x: auto;
        scrollbar-width: none;
      }
      .nav-cats ul::-webkit-scrollbar { display: none; }
      .nav-cats a {
        display: block;
        padding: 6px 12px;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--muted);
        border-radius: var(--radius-sm);
        transition: color .15s, background .15s;
        white-space: nowrap;
        text-decoration: none;
      }
      .nav-cats a:hover { color: var(--ink); background: var(--line-2); text-decoration: none; }
      .nav-cats a.active { color: var(--accent); background: var(--accent-soft); }
      .nav-cats a[data-cat="energy"].active  { color: var(--cat-energy);  background: var(--cat-energy-soft); }
      .nav-cats a[data-cat="economy"].active { color: var(--cat-economy); background: var(--cat-economy-soft); }
      .nav-cats a[data-cat="ai"].active      { color: var(--cat-ai);      background: var(--cat-ai-soft); }
      .nav-cats a[data-cat="life"].active    { color: var(--cat-life);    background: var(--cat-life-soft); }

      .nav-actions {
        display: flex;
        align-items: center;
        gap: 6px;
        flex: none;
      }
      .nav-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 34px; height: 34px;
        background: none;
        border: 1px solid var(--line);
        border-radius: 999px;
        color: var(--muted);
        cursor: pointer;
        transition: color .15s, border-color .15s, background .15s;
        text-decoration: none;
      }
      .nav-btn:hover { color: var(--accent); border-color: var(--accent); background: var(--accent-soft); text-decoration: none; }
      .nav-btn .icon-sun { display: none; }
      [data-theme="dark"] .nav-btn .icon-moon { display: none; }
      [data-theme="dark"] .nav-btn .icon-sun { display: inline-flex; }

      /* ── NOTICE WIRE (below nav) ───────────── */
      a.notice-wire {
        display: flex;
        align-items: center;
        gap: 10px;
        max-width: var(--max-w);
        margin: 12px auto;
        padding: 10px 20px;
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        background: linear-gradient(180deg, var(--accent-soft), var(--notice-grad-end));
        color: var(--ink);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 600;
        line-height: 1.3;
        transition: border-color .15s, transform .15s, box-shadow .15s;
        /* left/right margins align with wide content */
        padding-left: 24px;
        padding-right: 24px;
      }
      a.notice-wire:hover {
        text-decoration: none;
        border-color: var(--accent);
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(122,63,242,.13);
      }
      .notice-tag {
        flex: none;
        font-size: 0.72rem; font-weight: 800; letter-spacing: 0.02em;
        padding: 3px 9px; border-radius: 999px;
        background: var(--accent); color: #fff;
      }
      .notice-title {
        flex: 1 1 auto;
        min-width: 0;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .notice-badge {
        flex: none;
        display: inline-flex; align-items: center; gap: 5px;
        font-size: 0.76rem; font-weight: 700; color: var(--accent);
      }
      .notice-badge .dot {
        width: 7px; height: 7px; border-radius: 50%;
        background: #e0392b;
        box-shadow: 0 0 0 0 rgba(224,57,43,.55);
        animation: notice-pulse 1.8s ease-out infinite;
      }
      @keyframes notice-pulse {
        0%   { box-shadow: 0 0 0 0 rgba(224,57,43,.55); }
        70%  { box-shadow: 0 0 0 6px rgba(224,57,43,0); }
        100% { box-shadow: 0 0 0 0 rgba(224,57,43,0); }
      }
      @media (prefers-reduced-motion: reduce) {
        .notice-badge .dot { animation: none; }
      }
      @media (max-width: 420px) { .notice-badge-text { display: none; } }

      /* ── MAIN CONTENT ──────────────────────── */
      main.wrap,
      main.wrap.wide {
        padding-top: 28px;
      }

      /* ── CATEGORY CHIP ─────────────────────── */
      .cat-chip {
        display: inline-block;
        font-size: 0.78rem; font-weight: 700; line-height: 1;
        padding: 4px 9px; border-radius: 999px;
        color: var(--accent); background: var(--accent-soft);
        text-decoration: none;
      }
      .cat-chip:hover { text-decoration: none; background: var(--accent); color: #fff; }

      /* ── GLOBAL LINKS / HEADINGS ───────────── */
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; text-underline-offset: 3px; }
      h1, h2, h3 { letter-spacing: -0.025em; line-height: 1.35; }

      /* ── ARTICLE PAGE STYLES ───────────────── */
      article h2 {
        margin-top: 2.2em;
        padding-left: 14px;
        border-left: 4px solid var(--accent);
      }
      article img { max-width: 100%; border-radius: 8px; }
      article code {
        background: var(--accent-soft);
        padding: 0.15em 0.4em;
        border-radius: 4px;
        font-size: 0.88em;
      }
      article pre { padding: 16px; border-radius: 10px; overflow-x: auto; font-size: 0.85em; }
      article pre code { background: none; padding: 0; }
      article blockquote {
        margin: 1.5em 0;
        padding: 4px 18px;
        border-left: 4px solid var(--line);
        color: var(--muted);
      }

      /* ── FOOTER ────────────────────────────── */
      footer.site {
        border-top: 1px solid var(--line);
        margin-top: 80px;
        padding: 32px 0 48px;
        color: var(--muted);
        font-size: 0.85rem;
      }

      time, .meta { color: var(--muted); font-size: 0.85rem; }

      :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; border-radius: 2px; }

      @media (prefers-reduced-motion: reduce) {
        * { transition: none !important; animation: none !important; }
      }

      /* ── RESPONSIVE NAV ─────────────────────── */
      @media (max-width: 767px) {
        :root { --nav-h: 48px; }
      }
    </style>
    <link rel="stylesheet" as="style" crossorigin
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />

    {/* Google AdSense */}
    {adsenseSrc && (
      <script is:inline async src={adsenseSrc} crossorigin="anonymous"></script>
    )}
    {/* Kakao AdFit */}
    {ADFIT_ENABLED && (
      <script is:inline async src="//t1.daumcdn.net/kas/static/ba.min.js"></script>
    )}

    <script is:inline>
      (function () {
        try {
          var p = new URLSearchParams(location.search);
          if (p.has('me')) {
            if (p.get('me') === 'off') {
              localStorage.removeItem('ga_exclude_owner');
            } else {
              localStorage.setItem('ga_exclude_owner', '1');
            }
          }
          window.__gaExcludeOwner = localStorage.getItem('ga_exclude_owner') === '1';
        } catch (e) {
          window.__gaExcludeOwner = false;
        }
      })();
    </script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-KM0XNWHRCM"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      if (window.__gaExcludeOwner) {
        window['ga-disable-G-KM0XNWHRCM'] = true;
      } else {
        gtag('config', 'G-KM0XNWHRCM', {
          language_version: location.pathname.startsWith('/en/') ? 'en' : 'ko'
        });
      }
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">콘텐츠로 건너뛰기</a>

    <!-- ── STICKY NAV ──────────────────────────── -->
    <nav class="site-nav" role="navigation" aria-label="주 메뉴">
      <div class="nav-inner">
        <a class="nav-logo" href="/">
          <svg class="logo-bolt" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M13 2L4 14h7l-1 8 10-12h-7l1-8z" fill="currentColor"/>
          </svg>
          <span>BASELOAD</span>
        </a>

        <nav class="nav-cats" aria-label="카테고리">
          <ul role="list">
            {navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[{ active: isActive(item.href) }]}
                  data-cat={item.cat ?? undefined}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="nav-actions">
          <button class="nav-btn theme-toggle" type="button" aria-label="다크 모드 전환">
            <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/>
            </svg>
            <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4"/>
              <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"/>
            </svg>
          </button>
          <a class="nav-btn" href="/rss.xml" aria-label="RSS 피드">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/>
              <circle cx="5" cy="19" r="1" fill="currentColor"/>
            </svg>
          </a>
        </div>
      </div>
    </nav>

    <!-- ── NOTICE WIRE ─────────────────────────── -->
    {showNotice && (
      <a class="notice-wire" href={NOTICE.href} aria-label={`공지: ${NOTICE.label}`}>
        <span class="notice-tag">공지</span>
        <span class="notice-title">{NOTICE.emoji} {NOTICE.label}</span>
        <span class="notice-badge">
          <span class="dot" aria-hidden="true"></span>
          <span class="notice-badge-text">{NOTICE.badge}</span>
        </span>
      </a>
    )}

    <!-- ── MAIN CONTENT ────────────────────────── -->
    <main id="main" class:list={['wrap', { wide }]}>
      <slot />
    </main>

    <footer class="site">
      <div class="wrap">
        © {new Date().getFullYear()} BASELOAD · <a href="/rss.xml">RSS</a>
      </div>
    </footer>

    <Analytics />

    <script is:inline>
      (function () {
        var btn = document.querySelector('.theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', function () {
          var cur = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
          var next = cur === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          try { localStorage.setItem('theme', next); } catch (e) {}
        });
      })();
    </script>
  </body>
</html>
