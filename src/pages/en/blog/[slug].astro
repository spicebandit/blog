---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Comments from '../../../components/Comments.astro';
import AdSlot from '../../../components/AdSlot.astro';
import SidebarEn from '../../../components/SidebarEn.astro';
import { formatDateEN } from '../../../lib/format';

export async function getStaticPaths() {
  const posts = await getCollection('blog-en', ({ data }) => !data.draft || import.meta.env.DEV);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const SITE = Astro.site!;

// 사이드바: 최근 영문 글 4개 (현재 글 제외, 발행순)
const allEnPosts = await getCollection('blog-en', ({ data }) => !data.draft);
const recentEnPosts = allEnPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const toc = headings.filter((h) => h.depth === 2);
const showToc = toc.length >= 3;

const plain = post.body
  ? post.body
      .replace(/```[\s\S]*?```/g, '')
      .replace(/!\[[^\]]*\]\([^)]*\)/g, '')
      .replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
      .replace(/[#>*`_~\-]/g, '')
  : '';
const readingMin = Math.max(1, Math.round(plain.replace(/\s/g, '').length / 200)); // English ~200 wpm

// OG 이미지: heroImage → 본문 첫 이미지 → 사이트 기본
const firstImg = post.body?.match(/!\[[^\]]*\]\((https?:\/\/[^)\s]+)\)/);
const ogImage = post.data.heroImage ?? firstImg?.[1];

// 브레드크럼 (영문): Home > 글제목
const breadcrumbs = [
  { name: 'Home', url: '/en/' },
  { name: post.data.title, url: `/en/blog/${post.id}/` },
];

const koSlug = post.data.koSlug ?? post.data.sourceSlug;
const hrefLangAlts = [
  { lang: 'en', href: new URL(`/en/blog/${post.id}/`, SITE).toString() },
  ...(koSlug ? [{ lang: 'ko', href: new URL(`/blog/${koSlug}/`, SITE).toString() }] : []),
  { lang: 'x-default', href: new URL(koSlug ? `/blog/${koSlug}/` : '/', SITE).toString() },
];
---
<Base
  title={post.data.title}
  description={post.data.description}
  type="article"
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  lang="en"
  wide={true}
  hrefLangAlts={hrefLangAlts}
  ogImage={ogImage}
  breadcrumbs={breadcrumbs}
  author={post.data.author}
>
  <div class="article-layout">
    <div class="article-main">
  <article data-pagefind-body data-pagefind-meta="lang:en">
    <p class="breadcrumb"><a href="/en/">← BASELOAD English</a></p>
    <h1>{post.data.title}</h1>
    <p class="post-meta">
      <time datetime={post.data.pubDate.toISOString()}>
        {formatDateEN(post.data.pubDate)}
      </time>
      <span class="reading-time">· {readingMin} min read</span>
      {koSlug && (
        <a href={`/blog/${koSlug}/`} class="ko-link">한국어 원문</a>
      )}
    </p>

    {showToc && (
      <nav class="toc" aria-label="Table of contents">
        <p class="toc-title">Contents</p>
        <ol>
          {toc.map((h) => (
            <li><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ol>
      </nav>
    )}

    <Content />

    {post.data.tags.length > 0 && (
      <div class="tag-list" aria-label="Tags">
        {post.data.tags.map((tag) => (
          <a class="tag-pill" href={`/tag/${encodeURIComponent(tag)}/`}>#{tag}</a>
        ))}
      </div>
    )}
    {/* 영문판은 해외 독자 대상이므로 애드센스만 (애드핏은 국내 전용) */}
    <AdSlot position="bottom" network="adsense" class="ad-en-bottom" />
  </article>
  <Comments pageId={`en-${post.id}`} pageTitle={post.data.title} />
    </div>
    <SidebarEn recentPosts={recentEnPosts} />
  </div>
</Base>

<style>
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 32px;
    align-items: start;
  }
  .article-main { min-width: 0; }
  .article-main article { max-width: 700px; }
  @media (max-width: 959px) {
    .article-layout { grid-template-columns: 1fr; }
  }

  .breadcrumb { margin: 0 0 1.5rem; font-size: 0.875rem; }
  .breadcrumb a { color: var(--muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin: 0 0 1.5em;
    font-size: 0.9rem;
    color: var(--muted);
  }
  .reading-time { color: var(--muted); font-size: 0.85rem; }
  .ko-link {
    color: var(--accent);
    font-size: 0.78rem;
    text-decoration: none;
    border: 1px solid var(--accent);
    padding: 2px 7px;
    border-radius: 4px;
  }
  .ko-link:hover { background: var(--accent-soft); }
  .toc {
    margin: 0 0 2.5em;
    padding: 16px 20px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--accent-soft);
  }
  .toc-title {
    margin: 0 0 8px;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--accent-text);
  }
  .toc ol {
    margin: 0;
    padding-left: 1.2em;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .toc li { line-height: 1.45; }
  .toc a { color: var(--ink); text-decoration: none; font-size: 0.94rem; }
  .toc a:hover { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  article :is(h2, h3) { scroll-margin-top: 20px; }
  html { scroll-behavior: smooth; }
  @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 3em;
    padding-top: 1.5em;
    border-top: 1px solid var(--line);
  }
  .tag-pill {
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1;
    padding: 7px 12px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--muted);
    background: transparent;
    text-decoration: none;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .tag-pill:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-soft);
    text-decoration: none;
  }
</style>
