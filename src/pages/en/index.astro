---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { formatDateEN } from '../../lib/format';

const SITE = Astro.site!;

const posts = (await getCollection('blog-en', ({ data }) => !data.draft || import.meta.env.DEV))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const hrefLangAlts = [
  { lang: 'ko', href: new URL('/', SITE).toString() },
  { lang: 'en', href: new URL('/en/', SITE).toString() },
  { lang: 'x-default', href: new URL('/', SITE).toString() },
];
---
<Base
  title="BASELOAD — Energy · Economy · AI"
  description="English articles on energy, economy, and AI from BASELOAD, South Korea's specialist media."
  lang="en"
  hrefLangAlts={hrefLangAlts}
  wide={true}
>
  <div class="en-home wrap wide">
    <header class="en-header">
      <p class="lang-notice">
        <a href="/">한국어 홈으로 →</a>
      </p>
      <h1>BASELOAD <span class="en-badge">English</span></h1>
      <p class="subtitle">Selected articles in English — Energy · Economy · AI</p>
    </header>

    {posts.length === 0 ? (
      <div class="empty-state">
        <p>English articles are coming soon. Our editorial team is currently translating and curating top posts.</p>
        <p><a href="/">Read our Korean articles →</a></p>
      </div>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-item">
            <a href={`/en/blog/${post.id}/`} class="post-link">
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              <span class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDateEN(post.data.pubDate)}
                </time>
                {post.data.koSlug && (
                  <a href={`/blog/${post.data.koSlug}/`} class="ko-link">한국어 원문</a>
                )}
              </span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Base>

<style>
  .en-home { padding-top: 2rem; }
  .en-header { margin-bottom: 2.5rem; }
  .lang-notice { margin: 0 0 1rem; font-size: 0.85rem; }
  .lang-notice a { color: var(--muted); text-decoration: none; }
  .lang-notice a:hover { color: var(--accent); }
  .en-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--accent);
    color: #fff;
    padding: 3px 8px;
    border-radius: 4px;
    vertical-align: middle;
    margin-left: 6px;
  }
  .subtitle { color: var(--muted); margin: 0.25rem 0 0; }
  .empty-state {
    padding: 3rem 0;
    color: var(--muted);
    line-height: 2;
  }
  .empty-state a { color: var(--accent); }
  .post-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1.5rem; }
  .post-item { border-bottom: 1px solid var(--line); padding-bottom: 1.5rem; }
  .post-link { text-decoration: none; color: inherit; display: block; }
  .post-link:hover .post-title { color: var(--accent); }
  .post-title { margin: 0 0 0.4rem; font-size: 1.2rem; }
  .post-desc { margin: 0 0 0.5rem; color: var(--ink-2); font-size: 0.95rem; line-height: 1.6; }
  .post-meta { font-size: 0.82rem; color: var(--muted); display: flex; gap: 1rem; align-items: center; }
  .ko-link { color: var(--accent); font-size: 0.78rem; text-decoration: none; border: 1px solid var(--accent); padding: 2px 7px; border-radius: 4px; }
  .ko-link:hover { background: var(--accent-soft); }
</style>
