---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import HeroSection from '../../components/HeroSection.astro';
import HomeSidebar from '../../components/HomeSidebar.astro';
import BriefList from '../../components/BriefList.astro';
import AdSlot from '../../components/AdSlot.astro';
import { firstBodyImage } from '../../lib/format';
import popularData from '../../data/popular-posts.json';

const SITE = Astro.site!;

// 영문판: AI·AX 글만 노출 (한글 홈과 동일 레이아웃, 문구만 영어)
const raw = (await getCollection('blog-en', ({ data }) =>
  (data.category === 'ai') && (!data.draft || import.meta.env.DEV)
)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const posts = raw.map((p) => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description,
  category: p.data.category,
  pubDate: p.data.pubDate,
  heroImage: p.data.heroImage || firstBodyImage(p.body),
}));

// 히어로: 최신 1건 리드 + 2건 서브 (영문은 발행 빈도가 낮아 최신 3건 고정)
const slides = posts.slice(0, 3);
const slideIds = new Set(slides.map(p => p.id));

// Most Read: GA4 순위에 있으면 우선, 없으면 최신순
const popularRankMap = new Map<string, number>(
  (popularData.posts as { slug: string; views: number }[]).map((p, i) => [p.slug, i])
);
const sidebarPosts = [...posts]
  .sort((a, b) => {
    const rankA = popularRankMap.has(a.id) ? popularRankMap.get(a.id)! : Infinity;
    const rankB = popularRankMap.has(b.id) ? popularRankMap.get(b.id)! : Infinity;
    if (rankA !== rankB) return rankA - rankB;
    return b.pubDate.valueOf() - a.pubDate.valueOf();
  })
  .slice(0, 5);

// Latest Brief: 히어로 제외 최신 6건
const briefPosts = posts.filter(p => !slideIds.has(p.id)).slice(0, 6);

const hrefLangAlts = [
  { lang: 'ko', href: new URL('/', SITE).toString() },
  { lang: 'en', href: new URL('/en/', SITE).toString() },
  { lang: 'x-default', href: new URL('/', SITE).toString() },
];
---
<Base
  title="BASELOAD — AI &amp; Agentic Intelligence"
  description="English articles on AI and agentic intelligence from BASELOAD, South Korea's specialist media on energy, economy, and technology."
  lang="en"
  hrefLangAlts={hrefLangAlts}
  wide={true}
>
  {posts.length === 0 ? (
    <div class="empty-state">
      <p>English articles are coming soon. Our editorial team is currently translating and curating top posts.</p>
      <p><a href="/">Read our Korean articles →</a></p>
    </div>
  ) : (
    <div class="home-grid">
      <div class="home-main">
        {slides.length > 0 && <HeroSection slides={slides} lang="en" baseHref="/en/blog/" />}
        {briefPosts.length > 0 && <BriefList posts={briefPosts} lang="en" baseHref="/en/blog/" />}
      </div>
      <HomeSidebar recent={sidebarPosts} lang="en" baseHref="/en/blog/" />
    </div>
  )}

  <div class="home-ad-bottom">
    <AdSlot position="bottom" network="adfit" />
  </div>
</Base>

<style>
  /* 한글 홈과 동일한 2단 구조 */
  .home-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 24px;
    align-items: start;
    margin-bottom: 44px;
  }
  .home-main { min-width: 0; }
  @media (max-width: 1023px) {
    .home-grid { grid-template-columns: 1fr; }
  }

  .empty-state {
    padding: 48px 0;
    color: var(--muted);
    font-family: var(--font-serif);
  }

  .home-ad-bottom {
    max-width: 1200px;
    margin: 8px auto 0;
    padding: 0 16px;
  }
</style>
