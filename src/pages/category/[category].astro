---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { CATEGORY_SLUGS, categoryName, type CategorySlug } from '../../lib/categories';

export async function getStaticPaths() {
  // 4개 카테고리 각각에 대해 페이지를 생성한다(글이 없는 카테고리도 빈 목록으로 생성).
  return CATEGORY_SLUGS.map((category) => ({ params: { category } }));
}

const category = Astro.params.category as CategorySlug;
const name = categoryName(category);

const posts = (await getCollection('blog', ({ data }) => (!data.draft || import.meta.env.DEV) && data.category === category))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base title={`${name} | 카테고리`} description={`${name} 카테고리의 글 모음입니다.`}>
  <h1 style="margin-bottom: 4px;">{name}</h1>
  <p class="meta" style="margin-top: 0;">{posts.length}개의 글</p>

  {posts.length === 0 ? (
    <p style="color: var(--muted); padding: 24px 0;">아직 이 카테고리에 글이 없습니다.</p>
  ) : (
    <ul style="list-style:none; padding:0; margin: 24px 0 0;">
      {posts.map((post) => (
        <li style="padding: 22px 0; border-bottom: 1px solid var(--line);">
          <a href={`/blog/${post.id}/`} style="color: var(--ink); font-weight: 700; font-size: 1.2rem;">
            {post.data.title}
          </a>
          <p style="margin: 6px 0 8px; color: var(--muted);">{post.data.description}</p>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </li>
      ))}
    </ul>
  )}
</Base>
