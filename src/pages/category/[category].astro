---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { CATEGORY_SLUGS, categoryName, type CategorySlug } from '../../lib/categories';

export async function getStaticPaths() {
  // 4개 카테고리 각각에 대해 페이지를 생성한다(글이 없는 카테고리도 빈 목록으로 생성).
  return CATEGORY_SLUGS.map((category) => ({ params: { category } }));
}

const category = Astro.params.category as CategorySlug;
const name = categoryName(category);

const rawPosts = (await getCollection('blog', ({ data }) => (!data.draft || import.meta.env.DEV) && data.category === category))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function extractFirstImage(body: string | undefined): string | undefined {
  if (!body) return undefined;
  const m = body.match(/!\[[^\]]*\]\((https?:\/\/[^)]+)\)/);
  return m?.[1];
}

const posts = rawPosts.map(p => ({ post: p, heroImage: p.data.heroImage ?? extractFirstImage(p.body) }));
---
<Base title={`${name} | 카테고리`} description={`${name} 카테고리의 글 모음입니다.`}>
  <h1 style="margin-bottom: 4px;">{name}</h1>
  <p class="meta" style="margin-top: 0;">{posts.length}개의 글</p>

  {posts.length === 0 ? (
    <p style="color: var(--muted); padding: 24px 0;">아직 이 카테고리에 글이 없습니다.</p>
  ) : (
    <ul style="list-style:none; padding:0; margin: 24px 0 0;">
      {posts.map(({ post, heroImage }) => (
        <PostCard
          id={post.id}
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          pubDate={post.data.pubDate}
          showCategory={false}
          heroImage={heroImage}
        />
      ))}
    </ul>
  )}
</Base>
