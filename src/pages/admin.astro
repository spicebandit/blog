---
// 관리자 분석 대시보드 (정적) — 비밀번호 입력 → /api/admin-stats 호출 → 렌더.
// 인증/데이터는 전부 서버에서 처리. 이 페이지엔 비밀이 없다.
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>BASELOAD · 관리자 분석</title>
  <style>
    :root{
      --ink:#1e293b; --muted:#64748b; --line:#e8ebf0; --line2:#f1f4f8;
      --accent:#2563eb; --soft:#eff4ff; --green:#15803d; --bg:#f5f7fa;
      --rad:14px; --pad:18px;
    }
    *{box-sizing:border-box;}
    html,body{margin:0;}
    body{font-family:-apple-system,"Apple SD Gothic Neo",Pretendard,system-ui,sans-serif;background:var(--bg);color:var(--ink);-webkit-font-smoothing:antialiased;}
    .wrap{max-width:880px;margin:0 auto;padding:6px 16px 64px;}
    /* 홈 로고 (왼쪽 위) */
    .brand{display:inline-flex;align-items:center;gap:5px;margin:16px 0 0 16px;font-weight:800;font-size:1.02rem;color:var(--ink);text-decoration:none;letter-spacing:-.01em;}
    .brand .bolt{color:var(--accent);}
    .brand:hover{opacity:.8;}

    /* 게이트 */
    .gate{max-width:340px;margin:14vh auto 0;background:#fff;border:1px solid var(--line);border-radius:16px;padding:26px 22px;box-shadow:0 1px 3px rgba(0,0,0,.04);}
    .gate h1{font-size:1.1rem;text-align:center;margin:0 0 16px;}
    input[type=password]{width:100%;padding:12px 13px;border:1px solid var(--line);border-radius:10px;font-size:1rem;}
    button{width:100%;padding:12px;border:0;border-radius:10px;background:var(--accent);color:#fff;font-weight:700;font-size:.98rem;cursor:pointer;margin-top:12px;}
    button:disabled{opacity:.55;}
    .err{color:#dc2626;font-size:.85rem;margin-top:10px;min-height:1.1em;text-align:center;}
    .hide{display:none;}

    /* 헤더 */
    .head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:4px;}
    .head h1{font-size:1.2rem;margin:0;}
    .sub{color:var(--muted);font-size:.8rem;margin:0 0 18px;}
    .reload{width:auto;padding:8px 14px;font-size:.82rem;background:#0f172a;margin:0;flex:none;}

    /* 요약 카드 */
    .cards{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:0 0 20px;}
    .card{background:#fff;border:1px solid var(--line);border-radius:var(--rad);padding:16px 14px;text-align:center;}
    .card .lbl{color:var(--muted);font-size:.74rem;margin-bottom:6px;}
    .card .big{font-size:1.55rem;font-weight:800;line-height:1.1;letter-spacing:-.02em;}
    .card .sm{font-size:.72rem;color:var(--muted);margin-top:5px;}
    @media(max-width:600px){.cards{grid-template-columns:repeat(2,1fr);}}

    /* 섹션 */
    section{background:#fff;border:1px solid var(--line);border-radius:var(--rad);padding:var(--pad);margin:0 0 14px;}
    section h2{font-size:.92rem;font-weight:700;margin:0 0 14px;display:flex;align-items:center;gap:7px;}
    .note{color:var(--muted);font-size:.76rem;margin-top:12px;line-height:1.5;}

    /* 표 (일관 정렬·간격) */
    .tbl{width:100%;overflow-x:auto;}
    table{width:100%;border-collapse:collapse;font-size:.86rem;}
    th,td{padding:9px 12px;border-bottom:1px solid var(--line2);text-align:left;white-space:nowrap;vertical-align:middle;}
    th{color:var(--muted);font-size:.72rem;font-weight:600;letter-spacing:.01em;background:#fafbfd;border-bottom:1px solid var(--line);}
    td.num,th.num{text-align:right;font-variant-numeric:tabular-nums;}
    td.wrap{white-space:normal;line-height:1.45;min-width:200px;}
    tr:last-child td{border-bottom:0;}
    tbody tr:hover{background:#fafbfd;}

    /* 분류 pill + 막대 */
    .pills{display:flex;gap:8px;flex-wrap:wrap;}
    .pill{display:inline-flex;align-items:center;gap:5px;padding:5px 11px;border-radius:999px;font-size:.78rem;font-weight:700;}
    .ext{background:#e7f6ef;color:var(--green);} .own{background:#eef2ff;color:#3730a3;} .bot{background:#f1f5f9;color:#64748b;}
    .stack{display:flex;height:10px;border-radius:6px;overflow:hidden;margin-top:12px;background:#f1f5f9;}
    .stack i{display:block;height:100%;}

    /* 일별 막대 */
    .bars{display:flex;flex-direction:column;gap:7px;}
    .brow{display:grid;grid-template-columns:46px 1fr 90px;align-items:center;gap:10px;font-size:.82rem;}
    .brow .d{color:var(--muted);font-variant-numeric:tabular-nums;}
    .brow .track{height:9px;background:#f1f5f9;border-radius:5px;overflow:hidden;}
    .brow .fill{height:100%;background:var(--accent);border-radius:5px;}
    .brow .v{text-align:right;color:var(--muted);font-size:.76rem;font-variant-numeric:tabular-nums;}

    .rt{display:inline-block;width:8px;height:8px;border-radius:50%;background:#22c55e;}
    .rtnum{font-size:1.35rem;font-weight:800;color:var(--green);margin-bottom:6px;}
  </style>
</head>
<body>
  <a href="/" class="brand" title="홈으로"><span class="bolt">⚡</span> BASELOAD</a>
  <div id="gate" class="gate">
    <h1>🔒 관리자 분석</h1>
    <input id="pw" type="password" placeholder="비밀번호" autocomplete="current-password" />
    <button id="login">들어가기</button>
    <div id="gerr" class="err"></div>
  </div>

  <div id="dash" class="wrap hide">
    <div class="head">
      <h1>📊 BASELOAD 접속 분석</h1>
      <button class="reload" id="reload">↻ 새로고침</button>
    </div>
    <p class="sub" id="meta"></p>

    <div class="cards" id="cards"></div>

    <section><h2>🙋 방문자 분류 <span style="color:var(--muted);font-weight:400;font-size:.8rem">· 최근 7일</span></h2>
      <div id="classify"></div>
      <p class="note">외부 = 한국 신규 · 본인 = 한국 재방문 · 봇 = 해외 데이터센터 등 (상한 추정치)</p></section>

    <section><h2>📈 일별 추이 <span style="color:var(--muted);font-weight:400;font-size:.8rem">· 14일 · 사용자</span></h2><div id="daily" class="bars"></div></section>

    <section><h2>🌍 지역별 <span style="color:var(--muted);font-weight:400;font-size:.8rem">· 최근 7일</span></h2><div id="cities"></div></section>

    <section><h2>📄 글별 조회·체류 <span style="color:var(--muted);font-weight:400;font-size:.8rem">· 최근 7일</span></h2><div id="pages"></div></section>

    <section><h2>🔗 유입경로 <span style="color:var(--muted);font-weight:400;font-size:.8rem">· 최근 7일</span></h2><div id="sources"></div></section>

    <section><h2>💻 기기 <span style="color:var(--muted);font-weight:400;font-size:.8rem">· 최근 7일</span></h2><div id="devices"></div></section>

    <section><h2><span class="rt"></span> 실시간 <span style="color:var(--muted);font-weight:400;font-size:.8rem">· 최근 30분</span></h2><div id="realtime"></div></section>
  </div>

  <script is:inline>
    const $=(id)=>document.getElementById(id);
    const esc=(s)=>String(s??'').replace(/[<>&]/g,c=>({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]));
    const nf=(n)=>Number(n||0).toLocaleString('ko-KR');
    const dur=(s)=>{s=Math.round(s||0);const m=Math.floor(s/60),x=s%60;return m?`${m}분 ${x}초`:`${x}초`;};
    const ymd=(d)=>d?`${+d.slice(4,6)}/${+d.slice(6)}`:'';
    // 표 생성: cols=[{h,num?,wrap?}], data=[[...]]
    function tbl(cols,data){
      if(!data.length) return '<p class="note">데이터 없음</p>';
      const cl=(c)=>[c.num?'num':'',c.wrap?'wrap':''].filter(Boolean).join(' ');
      const head='<tr>'+cols.map(c=>`<th class="${cl(c)}">${c.h}</th>`).join('')+'</tr>';
      const body=data.map(r=>'<tr>'+r.map((v,i)=>`<td class="${cl(cols[i])}">${v}</td>`).join('')+'</tr>').join('');
      return `<div class="tbl"><table><thead>${head}</thead><tbody>${body}</tbody></table></div>`;
    }

    async function load(pw){
      $('login').disabled=true; $('gerr').textContent='불러오는 중…';
      let res; try{ res=await fetch('/api/admin-stats',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({password:pw})});}
      catch(e){ $('gerr').textContent='네트워크 오류'; $('login').disabled=false; return; }
      const d=await res.json().catch(()=>({error:'응답 오류'}));
      $('login').disabled=false;
      if(!res.ok){ $('gerr').textContent=d.error||('오류 '+res.status); sessionStorage.removeItem('adminpw'); return; }
      sessionStorage.setItem('adminpw',pw);
      $('gate').classList.add('hide'); $('dash').classList.remove('hide'); render(d);
    }

    function render(d){
      $('meta').textContent='갱신 '+new Date(d.generatedAt).toLocaleString('ko-KR');
      const c=(lbl,t)=>`<div class="card"><div class="lbl">${lbl}</div><div class="big">${nf(t.users)}</div><div class="sm">세션 ${nf(t.sessions)} · 조회 ${nf(t.views)}</div></div>`;
      $('cards').innerHTML=c('오늘',d.summary.today)+c('어제',d.summary.yesterday)+c('최근 7일',d.summary.last7)+c('최근 30일',d.summary.last30);

      const cl=d.classify, tot=(cl.external+cl.owner+cl.bot)||1, pct=(n)=>Math.round(n/tot*100);
      $('classify').innerHTML=
        `<div class="pills"><span class="pill ext">외부 ${nf(cl.external)}명</span><span class="pill own">본인 ${nf(cl.owner)}명</span><span class="pill bot">봇/해외 ${nf(cl.bot)}명</span></div>`+
        `<div class="stack"><i class="ext" style="width:${pct(cl.external)}%;background:#15803d"></i><i style="width:${pct(cl.owner)}%;background:#6366f1"></i><i style="width:${pct(cl.bot)}%;background:#cbd5e1"></i></div>`;

      const mx=Math.max(1,...d.daily.map(x=>x.users));
      $('daily').innerHTML=d.daily.map(x=>
        `<div class="brow"><span class="d">${ymd(x.date)}</span><span class="track"><span class="fill" style="width:${Math.round(x.users/mx*100)}%"></span></span><span class="v">${nf(x.users)}명 · ${nf(x.views)}</span></div>`).join('');

      $('cities').innerHTML=tbl(
        [{h:'도시'},{h:'국가'},{h:'사용자',num:true},{h:'조회',num:true}],
        d.cities.map(x=>[esc(x.city),esc(x.country),nf(x.users),nf(x.views)]));

      $('pages').innerHTML=tbl(
        [{h:'글',wrap:true},{h:'조회',num:true},{h:'사용자',num:true},{h:'평균 체류',num:true}],
        d.pages.map(x=>[esc(x.title),nf(x.views),nf(x.users),dur(x.avgSec)]));

      $('sources').innerHTML=tbl(
        [{h:'소스'},{h:'매체'},{h:'세션',num:true}],
        d.sources.map(x=>[esc(x.source),esc(x.medium),nf(x.sessions)]));

      $('devices').innerHTML=tbl(
        [{h:'기기'},{h:'사용자',num:true}],
        d.devices.map(x=>[esc(x.device),nf(x.users)]));

      const rt=d.realtime;
      $('realtime').innerHTML=`<div class="rtnum">${nf(rt.active)}명 활성</div>`+
        (rt.pages.length? tbl([{h:'보는 화면',wrap:true},{h:'인원',num:true}], rt.pages.map(x=>[esc(x.page),nf(x.n)])) : '<p class="note">지금 활성 사용자 없음</p>');
    }

    $('login').onclick=()=>{const pw=$('pw').value.trim(); if(pw) load(pw);};
    $('pw').addEventListener('keydown',e=>{if(e.key==='Enter')$('login').click();});
    $('reload').onclick=()=>{const pw=sessionStorage.getItem('adminpw'); if(pw) load(pw);};
    const saved=sessionStorage.getItem('adminpw'); if(saved) load(saved);
  </script>
</body>
</html>
