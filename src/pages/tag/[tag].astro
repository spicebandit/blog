---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft || import.meta.env.DEV);
  // 모든 글의 태그를 모아 중복 제거 → 태그별 페이지 생성
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => {
    const tagged = posts
      .filter((p) => p.data.tags.includes(tag))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
    return { params: { tag }, props: { tag, posts: tagged } };
  });
}

const { tag, posts: rawTagPosts } = Astro.props;

function extractFirstImage(body: string | undefined): string | undefined {
  if (!body) return undefined;
  const m = body.match(/!\[[^\]]*\]\((https?:\/\/[^)]+)\)/);
  return m?.[1];
}

const posts = rawTagPosts.map((p: any) => ({ post: p, heroImage: p.data.heroImage ?? extractFirstImage(p.body) }));
---
<Base title={`#${tag} | 태그`} description={`'${tag}' 태그가 달린 글 모음입니다.`}>
  <p class="meta" style="margin: 0 0 4px;">태그</p>
  <h1 style="margin: 0 0 4px;">#{tag}</h1>
  <p class="meta" style="margin-top: 0;">{posts.length}개의 글</p>

  <ul style="list-style:none; padding:0; margin: 24px 0 0;">
    {posts.map(({ post, heroImage }: { post: any; heroImage: string | undefined }) => (
      <PostCard
        id={post.id}
        title={post.data.title}
        description={post.data.description}
        category={post.data.category}
        pubDate={post.data.pubDate}
        heroImage={heroImage}
      />
    ))}
  </ul>
</Base>
