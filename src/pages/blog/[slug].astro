---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Comments from '../../components/Comments.astro';
import AdSlot from '../../components/AdSlot.astro';
import Sidebar from '../../components/Sidebar.astro';
import { categoryName } from '../../lib/categories';
import { formatDateKR } from '../../lib/format';

export async function getStaticPaths() {
  // draft 글도 URL은 생성한다 (검수용 프리뷰 링크).
  // 목록·RSS·사이트맵은 draft를 걸러내고 noindex 처리되므로, 링크를 아는 사람만 접근 가능.
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const isPreview = post.data.draft === true;

// OG 이미지: heroImage → 본문 첫 이미지 → (Base에서) 사이트 기본 카드
const firstImg = post.body?.match(/!\[[^\]]*\]\((https?:\/\/[^)\s]+)\)/);
const ogImage = post.data.heroImage ?? firstImg?.[1];

// 브레드크럼: 홈 > 카테고리 > 글제목
const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: categoryName(post.data.category), url: `/category/${post.data.category}/` },
  { name: post.data.title, url: `/blog/${post.id}/` },
];

// hreflang 상호선언: 영문판(blog-en)이 있으면 ko↔en 쌍으로 알린다 (구글은 단방향 선언 무시)
const SITE = Astro.site!;
const enPosts = await getCollection('blog-en');
const enMatch = enPosts.find((p) => (p.data.koSlug ?? p.data.sourceSlug ?? p.id) === post.id);
const hrefLangAlts = enMatch
  ? [
      { lang: 'ko', href: new URL(`/blog/${post.id}/`, SITE).toString() },
      { lang: 'en', href: new URL(`/en/blog/${enMatch.id}/`, SITE).toString() },
      { lang: 'x-default', href: new URL(`/blog/${post.id}/`, SITE).toString() },
    ]
  : undefined;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = sorted.filter(p => p.id !== post.id).slice(0, 4);
const catPosts = sorted.filter(p =>
  p.id !== post.id && p.data.category === post.data.category
).slice(0, 3);

// 목차: h2만 사용. 소제목이 3개 이상인 긴 글에서만 노출.
const toc = headings.filter((h) => h.depth === 2);
const showToc = toc.length >= 3;

// 읽기 시간: 본문에서 코드/이미지/링크 URL을 걷어낸 글자 수 기준(한글 ~500자/분).
const plain = post.body
  ? post.body
      .replace(/```[\s\S]*?```/g, '')
      .replace(/!\[[^\]]*\]\([^)]*\)/g, '')
      .replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
      .replace(/[#>*`_~\-]/g, '')
  : '';
const readingMin = Math.max(1, Math.round(plain.replace(/\s/g, '').length / 500));
---
<Base
  title={post.data.title}
  description={post.data.description}
  type="article"
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  wide={true}
  hrefLangAlts={hrefLangAlts}
  noindex={isPreview}
  ogImage={ogImage}
  breadcrumbs={breadcrumbs}
  author={post.data.author}
>
  <!-- ② 읽기 진행바: 스크롤 진행도를 상단 레드 라인으로 표시 -->
  <div class="read-progress" aria-hidden="true"></div>

  {isPreview && (
    <div class="preview-banner" role="status">
      검수용 미리보기 — 아직 발행 전 초안입니다. 목록·검색에 노출되지 않습니다.
    </div>
  )}

  <div class="article-layout">
    <div class="article-main">
      <article data-pagefind-body={isPreview ? undefined : true}>
        <h1>{post.data.title}</h1>
        <p style="display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin: 0 0 1.5em;">
          <a href={`/category/${post.data.category}/`} class="cat-chip">{categoryName(post.data.category)}</a>
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDateKR(post.data.pubDate)}
          </time>
          <span class="reading-time">· 약 {readingMin}분</span>
        </p>
        {showToc && (
          <nav class="toc" aria-label="목차">
            <p class="toc-title">목차</p>
            <ol>
              {toc.map((h) => (
                <li><a href={`#${h.slug}`}>{h.text.replace(/^\s*\d+[.)]\s*/, '')}</a></li>
              ))}
            </ol>
          </nav>
        )}
        <div class="article-body"><Content /></div>

        {post.data.tags.length > 0 && (
          <div class="tag-list" aria-label="태그">
            {post.data.tags.map((tag) => (
              <a class="tag-pill" href={`/tag/${encodeURIComponent(tag)}/`}>#{tag}</a>
            ))}
          </div>
        )}
      </article>
      {/* 슬롯 3: 기사 하단 (댓글 위) */}
      <AdSlot position="bottom" class="ad-article-bottom" />
      <Comments pageId={post.id} pageTitle={post.data.title} />
    </div>
    <Sidebar recentPosts={recentPosts} catPosts={catPosts} category={post.data.category} />
  </div>
</Base>

<script>
  // ② 읽기 진행바: 문서 스크롤 비율만큼 상단 바 폭 갱신
  const bar = document.querySelector('.read-progress') as HTMLElement | null;
  if (bar) {
    const update = () => {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const ratio = max > 0 ? Math.min(1, window.scrollY / max) : 0;
      bar.style.transform = `scaleX(${ratio})`;
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
  }
</script>

<style>
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 32px;
    align-items: start;
  }
  .article-main { min-width: 0; }
  .article-main article {
    max-width: 700px; /* 읽기 가독폭 ≈ 신문 한 단(줄이 너무 길지 않게) */
  }

  /* 신문 디테일: 첫 문단 드롭캡 */
  .article-body > :global(p:first-of-type)::first-letter {
    font-family: var(--font-serif);
    float: left;
    font-size: 3.1em;
    line-height: 0.85;
    font-weight: 700;
    padding: 4px 10px 0 0;
    color: var(--ink);
  }
  @media (max-width: 959px) {
    .article-layout {
      grid-template-columns: 1fr;
    }
  }

  .reading-time { color: var(--muted); font-size: 0.85rem; }

  /* 검수용 프리뷰 배너 */
  .preview-banner {
    background: var(--accent-soft);
    border: 1px dashed var(--accent);
    border-radius: 8px;
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 10px 14px;
    margin-bottom: 20px;
  }

  /* ② 읽기 진행바 */
  .read-progress {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    z-index: 100;
  }

  .toc {
    margin: 0 0 2.5em;
    padding: 16px 20px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--accent-soft);
  }
  .toc-title {
    margin: 0 0 8px;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--accent-text);
  }
  .toc ol {
    margin: 0;
    padding-left: 1.2em;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .toc li { line-height: 1.45; }
  .toc a {
    color: var(--ink);
    text-decoration: none;
    font-size: 0.94rem;
  }
  .toc a:hover { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  article :is(h2, h3) { scroll-margin-top: 20px; }
  html { scroll-behavior: smooth; }
  @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 3em;
    padding-top: 1.5em;
    border-top: 1px solid var(--line);
  }
  .tag-pill {
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1;
    padding: 7px 12px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--muted);
    background: transparent;
    text-decoration: none;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .tag-pill:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-soft);
    text-decoration: none;
  }
</style>
