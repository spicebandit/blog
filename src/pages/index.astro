---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import HomeSidebar from '../components/HomeSidebar.astro';
import BriefList from '../components/BriefList.astro';
import CategorySection from '../components/CategorySection.astro';
import AdSlot from '../components/AdSlot.astro';
import type { CategorySlug } from '../lib/categories';
import { CATEGORY_SLUGS } from '../lib/categories';
import { firstBodyImage, kstDateStr } from '../lib/format';
import popularData from '../data/popular-posts.json';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft || import.meta.env.DEV))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function postToSlide(p: (typeof allPosts)[0]) {
  return {
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    category: p.data.category,
    pubDate: p.data.pubDate,
    heroImage: p.data.heroImage || firstBodyImage(p.body),
    author: p.data.author,
    readingTime: p.data.readingTime,
  };
}

const buildDate = new Date();
const todayStr = kstDateStr(buildDate);
const yesterdayStr = kstDateStr(new Date(buildDate.getTime() - 86400000));

// 히어로: 그날 올린 기사 전부 노출 (리드 1 + 나머지 서브).
// 오늘 발행분이 없으면 어제 발행분, 그것도 없으면 최신 1건(리드만).
let todayPickSource = allPosts.filter(p => kstDateStr(p.data.pubDate) === todayStr);
if (todayPickSource.length === 0)
  todayPickSource = allPosts.filter(p => kstDateStr(p.data.pubDate) === yesterdayStr);
if (todayPickSource.length === 0)
  todayPickSource = allPosts.slice(0, 1);

const todayPickSlides = todayPickSource.map(postToSlide);
const todayPickIds = new Set(todayPickSlides.map(p => p.id));

// 많이 본 기사 (사이드바): GA4 7일 조회수 순위
const popularRankMap = new Map<string, number>(
  (popularData.posts as { slug: string; views: number }[]).map((p, i) => [p.slug, i])
);

const sidebarPosts = [...allPosts]
  .sort((a, b) => {
    const rankA = popularRankMap.has(a.id) ? popularRankMap.get(a.id)! : Infinity;
    const rankB = popularRankMap.has(b.id) ? popularRankMap.get(b.id)! : Infinity;
    if (rankA !== rankB) return rankA - rankB;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 5) // 사이드바 '가장 많이 읽은 글' 5개
  .map(postToSlide);

// Latest Brief: 최신 6개, todayPick·사이드바와 겹치지 않도록 제외
const sidebarIds = new Set(sidebarPosts.map(p => p.id));
const briefPosts = allPosts
  .filter(p => !todayPickIds.has(p.id) && !sidebarIds.has(p.id))
  .slice(0, 6)
  .map(p => ({
    id: p.id,
    title: p.data.title,
    category: p.data.category,
    pubDate: p.data.pubDate,
    heroImage: p.data.heroImage || firstBodyImage(p.body),
    author: p.data.author,
  }));

// Category sections: 카테고리별 최신 4개 (헤더의 편수는 카테고리 전체 글 수)
const byCat = (cat: CategorySlug) =>
  allPosts
    .filter(p => p.data.category === cat)
    .slice(0, 4)
    .map(postToSlide);
const catTotal = (cat: CategorySlug) =>
  allPosts.filter(p => p.data.category === cat).length;

// hreflang 상호선언: 한글 홈 ↔ 영문 홈
const SITE = Astro.site!;
const hrefLangAlts = [
  { lang: 'ko', href: new URL('/', SITE).toString() },
  { lang: 'en', href: new URL('/en/', SITE).toString() },
  { lang: 'x-default', href: new URL('/', SITE).toString() },
];
---
<Base title="BASELOAD" description="에너지·경제·AI·일상을 다루는 뉴스 블로그" wide={true} hrefLangAlts={hrefLangAlts}>

  <!-- 좌: 히어로(그날 기사) + Latest Brief가 빈틈없이 이어짐 / 우: 독립 사이드바 -->
  <div class="home-grid">
    <div class="home-main">
      {todayPickSlides.length > 0 && <HeroSection slides={todayPickSlides} />}
      {briefPosts.length > 0 && <BriefList posts={briefPosts} />}
    </div>
    <HomeSidebar recent={sidebarPosts} />
  </div>

  <!-- Category sections × 4 -->
  {CATEGORY_SLUGS.map((cat) => (
    <CategorySection category={cat} posts={byCat(cat)} total={catTotal(cat)} />
  ))}

  {/* 홈 최하단 광고 (AdFit 가로 배너, PC 728×90 / 모바일 320×50) */}
  <div class="home-ad-bottom">
    <AdSlot position="bottom" network="adfit" />
  </div>

</Base>

<style>
  /* 좌(히어로+브리프) / 우(사이드바) 독립 2단 — 사이드바는 자체 높이로만 */
  .home-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 24px;
    align-items: start;
    margin-bottom: 44px;
  }
  .home-main { min-width: 0; }
  @media (max-width: 1023px) {
    .home-grid { grid-template-columns: 1fr; }
  }

  .home-ad-bottom {
    max-width: 1200px;
    margin: 8px auto 0;
    padding: 0 16px;
  }
</style>
