---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import ArticleCard from '../components/ArticleCard.astro';
import CategorySection from '../components/CategorySection.astro';
import AdSlot from '../components/AdSlot.astro';
import type { CategorySlug } from '../lib/categories';
import { CATEGORY_SLUGS } from '../lib/categories';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft || import.meta.env.DEV))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Extract the first Unsplash/http image URL from a markdown body when heroImage frontmatter is absent
function firstBodyImage(body: string | undefined): string | undefined {
  if (!body) return undefined;
  const m = body.match(/!\[[^\]]*\]\((https?:\/\/[^)\s]+)\)/);
  return m?.[1];
}

const featured = allPosts.find((p) => p.data.featured);
const remaining = featured ? allPosts.filter((p) => p.id !== featured.id) : allPosts;

// Sidebar: 5 most recent excluding featured
const sidebarPosts = remaining.slice(0, 5).map((p) => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description,
  category: p.data.category,
  pubDate: p.data.pubDate,
  heroImage: p.data.heroImage || firstBodyImage(p.body),
  author: p.data.author,
  readingTime: p.data.readingTime,
}));

// Featured grid: next 3 after featured
const featuredGrid = remaining.slice(0, 3);

// Category sections: latest 3 per category, excluding featured
const byCat = (cat: CategorySlug) =>
  allPosts
    .filter((p) => p.data.category === cat && p.id !== featured?.id)
    .slice(0, 3)
    .map((p) => ({
      id: p.id,
      title: p.data.title,
      description: p.data.description,
      category: p.data.category,
      pubDate: p.data.pubDate,
      heroImage: p.data.heroImage || firstBodyImage(p.body),
      author: p.data.author,
      readingTime: p.data.readingTime,
    }));
---
<Base title="BASELOAD" description="에너지·경제·AI·일상을 다루는 뉴스 블로그" wide={true}>

  <!-- Hero: featured article + recent sidebar -->
  {featured ? (
    <HeroSection
      featured={{
        id: featured.id,
        title: featured.data.title,
        description: featured.data.description,
        category: featured.data.category,
        pubDate: featured.data.pubDate,
        heroImage: featured.data.heroImage || firstBodyImage(featured.body),
        author: featured.data.author,
        readingTime: featured.data.readingTime,
        series: featured.data.series,
        seriesParts: featured.data.seriesParts,
      }}
      recent={sidebarPosts}
    />
  ) : null}

  <!-- Featured grid: 3 most-recent articles -->
  {featuredGrid.length > 0 && (
    <section class="featured-section" aria-label="최신 기사">
      <div class="section-header">
        <h2 class="section-title">최신 기사</h2>
      </div>
      <div class="featured-grid">
        {featuredGrid.map((post) => (
          <ArticleCard
            id={post.id}
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            pubDate={post.data.pubDate}
            heroImage={post.data.heroImage || firstBodyImage(post.body)}
            author={post.data.author}
            readingTime={post.data.readingTime}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Ad band -->
  <div class="ad-band">
    <AdSlot size="leaderboard" />
  </div>

  <!-- Category sections × 4 -->
  {CATEGORY_SLUGS.map((cat) => (
    <CategorySection category={cat} posts={byCat(cat)} />
  ))}

</Base>

<style>
.featured-section { margin-bottom: 40px; }

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 2px solid var(--line);
  position: relative;
}
.section-header::after {
  content: '';
  position: absolute;
  left: 0; bottom: -2px;
  width: 48px; height: 2px;
  background: var(--accent);
  border-radius: 1px;
}
.section-title {
  font-size: 1.25rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--ink);
  margin: 0;
}

.featured-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.ad-band { margin: 32px 0; }

@media (max-width: 1023px) {
  .featured-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 767px) {
  .featured-grid { grid-template-columns: 1fr; }
}
</style>
