---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import BriefList from '../components/BriefList.astro';
import CategorySection from '../components/CategorySection.astro';
import AdSlot from '../components/AdSlot.astro';
import type { CategorySlug } from '../lib/categories';
import { CATEGORY_SLUGS } from '../lib/categories';
import { firstBodyImage, kstDateStr } from '../lib/format';
import popularData from '../data/popular-posts.json';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft || import.meta.env.DEV))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function postToSlide(p: (typeof allPosts)[0]) {
  return {
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    category: p.data.category,
    pubDate: p.data.pubDate,
    heroImage: p.data.heroImage || firstBodyImage(p.body),
    author: p.data.author,
    readingTime: p.data.readingTime,
  };
}

const buildDate = new Date();
const todayStr = kstDateStr(buildDate);
const yesterdayStr = kstDateStr(new Date(buildDate.getTime() - 86400000));

// Today Pick 캐러셀: 오늘 발행 → 없으면 어제 발행 → 없으면 최신 3개 폴백
let todayPickSource = allPosts.filter(p => kstDateStr(p.data.pubDate) === todayStr);
if (todayPickSource.length === 0)
  todayPickSource = allPosts.filter(p => kstDateStr(p.data.pubDate) === yesterdayStr);
if (todayPickSource.length === 0)
  todayPickSource = allPosts.slice(0, 3);

const todayPickSlides = todayPickSource.slice(0, 5).map(postToSlide);
const todayPickIds = new Set(todayPickSlides.map(p => p.id));

// 많이 본 기사 (사이드바): GA4 7일 조회수 순위
const popularRankMap = new Map<string, number>(
  (popularData.posts as { slug: string; views: number }[]).map((p, i) => [p.slug, i])
);

const sidebarPosts = [...allPosts]
  .sort((a, b) => {
    const rankA = popularRankMap.has(a.id) ? popularRankMap.get(a.id)! : Infinity;
    const rankB = popularRankMap.has(b.id) ? popularRankMap.get(b.id)! : Infinity;
    if (rankA !== rankB) return rankA - rankB;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 4)
  .map(postToSlide);

// Latest Brief: 최신 6개, todayPick·사이드바와 겹치지 않도록 제외
const sidebarIds = new Set(sidebarPosts.map(p => p.id));
const briefPosts = allPosts
  .filter(p => !todayPickIds.has(p.id) && !sidebarIds.has(p.id))
  .slice(0, 6)
  .map(p => ({
    id: p.id,
    title: p.data.title,
    category: p.data.category,
    pubDate: p.data.pubDate,
    heroImage: p.data.heroImage || firstBodyImage(p.body),
    author: p.data.author,
  }));

// Category sections: 카테고리별 최신 3개
const byCat = (cat: CategorySlug) =>
  allPosts
    .filter(p => p.data.category === cat)
    .slice(0, 3)
    .map(postToSlide);
---
<Base title="BASELOAD" description="에너지·경제·AI·일상을 다루는 뉴스 블로그" wide={true}>

  <!-- Hero: Today Pick carousel + 많이 본 기사 sidebar -->
  {todayPickSlides.length > 0 && (
    <HeroSection
      slides={todayPickSlides}
      recent={sidebarPosts}
    />
  )}

  <!-- Latest Brief: horizontal card list (6 articles) -->
  {briefPosts.length > 0 && <BriefList posts={briefPosts} />}

  <!-- Ad band -->
  <div class="ad-band">
    <AdSlot position="header" />
  </div>

  <!-- Category sections × 4 -->
  {CATEGORY_SLUGS.map((cat) => (
    <CategorySection category={cat} posts={byCat(cat)} />
  ))}

</Base>

<style>
.ad-band { margin: 32px 0; }
</style>
