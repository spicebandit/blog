---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import BriefList from '../components/BriefList.astro';
import CategorySection from '../components/CategorySection.astro';
import AdSlot from '../components/AdSlot.astro';
import type { CategorySlug } from '../lib/categories';
import { CATEGORY_SLUGS } from '../lib/categories';
import popularData from '../data/popular-posts.json';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft || import.meta.env.DEV))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Extract the first Unsplash/http image URL from a markdown body when heroImage frontmatter is absent
function firstBodyImage(body: string | undefined): string | undefined {
  if (!body) return undefined;
  const m = body.match(/!\[[^\]]*\]\((https?:\/\/[^)\s]+)\)/);
  return m?.[1];
}

const featured = allPosts.find((p) => p.data.featured);
const remaining = featured ? allPosts.filter((p) => p.id !== featured.id) : allPosts;

// 최근 7일 조회수 순위맵: slug → rank (0부터, 낮을수록 인기)
const popularRankMap = new Map<string, number>(
  (popularData.posts as { slug: string; views: number }[]).map((p, i) => [p.slug, i])
);

// 에디터픽(사이드바): 최근 7일 조회수 내림차순, 미집계 글은 최신순으로 후순위
const sidebarPosts = [...remaining]
  .sort((a, b) => {
    const rankA = popularRankMap.has(a.id) ? popularRankMap.get(a.id)! : Infinity;
    const rankB = popularRankMap.has(b.id) ? popularRankMap.get(b.id)! : Infinity;
    if (rankA !== rankB) return rankA - rankB;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 7)
  .map((p) => ({
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    category: p.data.category,
    pubDate: p.data.pubDate,
    heroImage: p.data.heroImage || firstBodyImage(p.body),
    author: p.data.author,
    readingTime: p.data.readingTime,
  }));

// Latest Brief: 최신 6개, 에디터픽과 겹치지 않도록 제외
const sidebarIds = new Set(sidebarPosts.map((p) => p.id));
const briefPosts = remaining
  .filter((p) => !sidebarIds.has(p.id))
  .slice(0, 6)
  .map((p) => ({
    id: p.id,
    title: p.data.title,
    category: p.data.category,
    pubDate: p.data.pubDate,
    heroImage: p.data.heroImage || firstBodyImage(p.body),
    author: p.data.author,
  }));

// Category sections: latest 3 per category, excluding featured
const byCat = (cat: CategorySlug) =>
  allPosts
    .filter((p) => p.data.category === cat && p.id !== featured?.id)
    .slice(0, 3)
    .map((p) => ({
      id: p.id,
      title: p.data.title,
      description: p.data.description,
      category: p.data.category,
      pubDate: p.data.pubDate,
      heroImage: p.data.heroImage || firstBodyImage(p.body),
      author: p.data.author,
      readingTime: p.data.readingTime,
    }));
---
<Base title="BASELOAD" description="에너지·경제·AI·일상을 다루는 뉴스 블로그" wide={true}>

  <!-- Hero: featured article + editor's pick sidebar -->
  {featured ? (
    <HeroSection
      featured={{
        id: featured.id,
        title: featured.data.title,
        description: featured.data.description,
        category: featured.data.category,
        pubDate: featured.data.pubDate,
        heroImage: featured.data.heroImage || firstBodyImage(featured.body),
        author: featured.data.author,
        readingTime: featured.data.readingTime,
      }}
      recent={sidebarPosts}
    />
  ) : null}

  <!-- Latest Brief: horizontal card list (6 articles) -->
  {briefPosts.length > 0 && <BriefList posts={briefPosts} />}

  <!-- Ad band -->
  <div class="ad-band">
    <AdSlot size="leaderboard" />
  </div>

  <!-- Category sections × 4 -->
  {CATEGORY_SLUGS.map((cat) => (
    <CategorySection category={cat} posts={byCat(cat)} />
  ))}

</Base>

<style>
.ad-band { margin: 32px 0; }
</style>
