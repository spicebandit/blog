---
import { categoryName, type CategorySlug } from '../lib/categories';
import { formatDateKRShort } from '../lib/format';

interface PostData {
  id: string;
  title: string;
  description: string;
  category: CategorySlug;
  pubDate: Date;
  heroImage?: string;
  author?: string;
  readingTime?: number;
}

interface Props {
  slides: PostData[];
}

const { slides } = Astro.props;

// 신문형: 리드 1건 + 나머지는 전부 서브(2단 그리드로 줄바꿈).
// 그날 올린 기사 수에 따라 서브 칸이 늘어나거나(4~5건) 사라진다(1건).
const lead = slides[0];
const subs = slides.slice(1);
---

<div class="hero-zone">
  <div class="hero-main">
    {lead && (
      <a class="lead-story" href={`/blog/${lead.id}/`}>
        <div class="kicker">{categoryName(lead.category)} · 심층분석</div>
        <div class="lead-grid">
          <div class="lead-body">
            <h2 class="lead-headline">{lead.title}</h2>
            <p class="lead-deck">{lead.description}</p>
            <div class="lead-meta">
              {lead.author && <span>{lead.author}</span>}
              {lead.author && <span class="sep">·</span>}
              <time datetime={lead.pubDate.toISOString()}>{formatDateKRShort(lead.pubDate)}</time>
              {lead.readingTime && <><span class="sep">·</span><span>{lead.readingTime}분 읽기</span></>}
            </div>
          </div>
          <div class="lead-image">
            {lead.heroImage
              ? <img src={lead.heroImage} alt="" loading="eager" />
              : <div class="lead-image-placeholder" aria-hidden="true"><span>BASELOAD</span></div>
            }
          </div>
        </div>
      </a>
    )}

    {subs.length > 0 && (
      <div class="sub-stories">
        {subs.map((post) => (
          <a class="sub-story" href={`/blog/${post.id}/`}>
            <div class="kicker">{categoryName(post.category)}</div>
            <h3 class="sub-headline">{post.title}</h3>
            <p class="sub-deck">{post.description}</p>
          </a>
        ))}
      </div>
    )}
  </div>
</div>

<style>
/* 히어로 단독 박스 — 사이드바와 분리, 자체 높이로만 움직인다 */
.hero-zone {
  margin-bottom: 36px;
  border: 1px solid var(--line);
  background: var(--bg);
}

.hero-main {
  padding: 30px 30px 32px;
  min-width: 0;
}

.kicker {
  font-family: var(--font-ui);
  font-size: 0.66rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
}

/* 리드 기사: 제목 좌 + 이미지 우 */
.lead-story {
  display: block;
  text-decoration: none;
  color: var(--ink);
}
.lead-story:hover { text-decoration: none; }
.lead-story:hover .lead-headline { color: var(--accent-dark); }

/* 키커 아래 제목·이미지 그리드 — 이미지가 제목 상단~기사내용 끝단에 꽉 차게 */
.lead-grid {
  margin-top: 12px;
  display: grid;
  grid-template-columns: 1fr 240px;
  gap: 30px;
  align-items: stretch; /* 이미지 하단 = 텍스트(메타) 끝단 정렬 */
}

.lead-headline {
  margin: 0;
  font-family: var(--font-serif);
  font-size: clamp(1.5rem, 3vw, 2.375rem);
  font-weight: 700;
  line-height: 1.14;
  letter-spacing: -0.015em;
  color: var(--ink);
  word-break: keep-all;
  text-wrap: balance;
  transition: color .15s;
}
.lead-deck {
  margin: 14px 0 0;
  font-family: var(--font-serif);
  font-size: 1rem;
  line-height: 1.55;
  color: var(--muted);
  word-break: keep-all;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}
.lead-meta {
  margin-top: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-ui);
  font-size: 0.6875rem;
  font-weight: 500;
  color: var(--muted);
}
.lead-meta .sep { color: var(--line); }

.lead-image {
  height: 100%;
  min-height: 160px;
  border: 1px solid var(--line);
  overflow: hidden;
}
.lead-image img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}
.lead-image-placeholder {
  width: 100%; height: 100%;
  background: linear-gradient(120deg, var(--accent-soft), var(--bg-2));
  display: flex; align-items: flex-end; padding: 12px;
}
.lead-image-placeholder span {
  font-family: var(--font-serif);
  font-size: 0.6875rem; font-weight: 700; color: var(--muted);
}

/* 서브 기사 2단 */
.sub-stories {
  margin-top: 26px;
  padding-top: 22px;
  border-top: 1px solid var(--line);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}
.sub-story {
  text-decoration: none;
  color: var(--ink);
  min-width: 0;
}
.sub-story:hover { text-decoration: none; }
.sub-story:hover .sub-headline { color: var(--accent-dark); }
.sub-headline {
  margin: 6px 0 4px;
  font-family: var(--font-serif);
  font-size: 1.25rem;
  font-weight: 600;
  line-height: 1.24;
  color: var(--ink);
  word-break: keep-all;
  transition: color .15s;
}
.sub-deck {
  margin: 0;
  font-family: var(--font-serif);
  font-size: 0.84rem;
  line-height: 1.5;
  color: var(--muted);
  word-break: keep-all;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ─── Responsive ─── */
@media (max-width: 767px) {
  .hero-main { padding: 20px 18px 24px; }
  .lead-grid { grid-template-columns: 1fr; gap: 16px; }
  .lead-image { order: -1; height: auto; aspect-ratio: 16/9; }
  .sub-stories { grid-template-columns: 1fr; gap: 18px; }
}
</style>
