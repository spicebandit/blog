---
import { categoryName, type CategorySlug } from '../lib/categories';
import { formatDateKRShort, formatDateKRCompact } from '../lib/format';

interface PostData {
  id: string;
  title: string;
  description: string;
  category: CategorySlug;
  pubDate: Date;
  heroImage?: string;
  author?: string;
  readingTime?: number;
}

interface Props {
  slides: PostData[];
  recent: PostData[];
}

const { slides, recent } = Astro.props;

// 신문형: 캐러셀 대신 리드 기사 1건 + 서브 기사 2건
const lead = slides[0];
const subs = slides.slice(1, 3);
---

<div class="hero-zone">
  <!-- 본판 (좌): 리드 기사 + 서브 기사 2단 -->
  <div class="hero-main">
    {lead && (
      <a class="lead-story" href={`/blog/${lead.id}/`}>
        <div class="lead-body">
          <div class="kicker">{categoryName(lead.category)} · 심층분석</div>
          <h2 class="lead-headline">{lead.title}</h2>
          <p class="lead-deck">{lead.description}</p>
          <div class="lead-meta">
            {lead.author && <span>{lead.author}</span>}
            {lead.author && <span class="sep">·</span>}
            <time datetime={lead.pubDate.toISOString()}>{formatDateKRShort(lead.pubDate)}</time>
            {lead.readingTime && <><span class="sep">·</span><span>{lead.readingTime}분 읽기</span></>}
          </div>
        </div>
        <div class="lead-image">
          {lead.heroImage
            ? <img src={lead.heroImage} alt="" loading="eager" />
            : <div class="lead-image-placeholder" aria-hidden="true"><span>BASELOAD</span></div>
          }
        </div>
      </a>
    )}

    {subs.length > 0 && (
      <div class="sub-stories">
        {subs.map((post) => (
          <a class="sub-story" href={`/blog/${post.id}/`}>
            <div class="kicker">{categoryName(post.category)}</div>
            <h3 class="sub-headline">{post.title}</h3>
            <p class="sub-deck">{post.description}</p>
          </a>
        ))}
      </div>
    )}
  </div>

  <!-- 사이드바 (우): 가장 많이 읽은 글 + 주간 브리핑 -->
  <aside class="hero-sidebar">
    {recent.length > 0 && (
      <div class="rank-section">
        <h3 class="rank-title">가장 많이 읽은 글</h3>
        <ol class="rank-list" role="list">
          {recent.slice(0, 4).map((post, i) => (
            <li class="rank-item">
              <a href={`/blog/${post.id}/`}>
                <span class="rank-num" aria-hidden="true">{i + 1}</span>
                <span class="rank-headline">{post.title}</span>
              </a>
            </li>
          ))}
        </ol>
      </div>
    )}

    <a class="brief-box" href="/rss.xml">
      <span class="brief-box-title">주간 브리핑</span>
      <span class="brief-box-desc">에너지·경제·AI 심층 기사를 RSS로 받아보세요.</span>
      <span class="brief-box-cta">무료 구독 →</span>
    </a>
  </aside>
</div>

<style>
.hero-zone {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 0;
  margin-bottom: 44px;
  border: 1px solid var(--line);
  background: var(--bg);
}

/* ─── 본판 (좌) ─── */
.hero-main {
  padding: 30px 30px 32px;
  border-right: 1px solid var(--line);
  min-width: 0;
}

.kicker {
  font-family: var(--font-ui);
  font-size: 0.66rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
}

/* 리드 기사: 제목 좌 + 이미지 우 */
.lead-story {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 30px;
  align-items: start;
  text-decoration: none;
  color: var(--ink);
}
.lead-story:hover { text-decoration: none; }
.lead-story:hover .lead-headline { color: var(--accent-dark); }

.lead-headline {
  margin: 12px 0 0;
  font-family: var(--font-serif);
  font-size: clamp(1.5rem, 3vw, 2.375rem);
  font-weight: 700;
  line-height: 1.14;
  letter-spacing: -0.015em;
  color: var(--ink);
  word-break: keep-all;
  text-wrap: balance;
  transition: color .15s;
}
.lead-deck {
  margin: 14px 0 0;
  font-family: var(--font-serif);
  font-size: 1rem;
  line-height: 1.55;
  color: var(--muted);
  word-break: keep-all;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}
.lead-meta {
  margin-top: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-ui);
  font-size: 0.6875rem;
  font-weight: 500;
  color: var(--muted);
}
.lead-meta .sep { color: var(--line); }

.lead-image {
  aspect-ratio: 4/3;
  border: 1px solid var(--line);
  overflow: hidden;
}
.lead-image img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}
.lead-image-placeholder {
  width: 100%; height: 100%;
  background: linear-gradient(120deg, var(--accent-soft), var(--bg-2));
  display: flex; align-items: flex-end; padding: 12px;
}
.lead-image-placeholder span {
  font-family: var(--font-serif);
  font-size: 0.6875rem; font-weight: 700; color: var(--muted);
}

/* 서브 기사 2단 */
.sub-stories {
  margin-top: 26px;
  padding-top: 22px;
  border-top: 1px solid var(--line);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}
.sub-story {
  text-decoration: none;
  color: var(--ink);
  min-width: 0;
}
.sub-story:hover { text-decoration: none; }
.sub-story:hover .sub-headline { color: var(--accent-dark); }
.sub-headline {
  margin: 6px 0 4px;
  font-family: var(--font-serif);
  font-size: 1.25rem;
  font-weight: 600;
  line-height: 1.24;
  color: var(--ink);
  word-break: keep-all;
  transition: color .15s;
}
.sub-deck {
  margin: 0;
  font-family: var(--font-serif);
  font-size: 0.84rem;
  line-height: 1.5;
  color: var(--muted);
  word-break: keep-all;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ─── 사이드바 (우) ─── */
.hero-sidebar {
  padding: 30px 26px;
  background: var(--bg-2);
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.rank-title {
  margin: 0 0 16px;
  font-family: var(--font-ui);
  font-size: 0.625rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ink);
  border-bottom: 2px solid var(--ink);
  padding-bottom: 8px;
}
.rank-list { list-style: none; margin: 0; padding: 0; }
.rank-item + .rank-item {
  border-top: 1px solid var(--line);
  margin-top: 14px;
  padding-top: 14px;
}
.rank-item a {
  display: flex;
  gap: 12px;
  text-decoration: none;
}
.rank-item a:hover { text-decoration: none; }
.rank-item a:hover .rank-headline { color: var(--accent-dark); }
.rank-num {
  flex: none;
  font-family: var(--font-serif);
  font-size: 1.375rem;
  font-weight: 700;
  line-height: 1;
  color: var(--accent);
}
.rank-headline {
  font-family: var(--font-serif);
  font-size: 0.9375rem;
  font-weight: 600;
  line-height: 1.32;
  color: var(--ink);
  word-break: keep-all;
  transition: color .15s;
}

/* 주간 브리핑 박스 → RSS */
.brief-box {
  display: block;
  padding: 16px;
  background: var(--ink);
  border-radius: var(--radius-md);
  text-decoration: none;
}
.brief-box:hover { text-decoration: none; }
.brief-box:hover .brief-box-cta { text-decoration: underline; text-underline-offset: 3px; }
.brief-box-title {
  display: block;
  font-family: var(--font-ui);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--bg);
  margin-bottom: 6px;
}
.brief-box-desc {
  display: block;
  font-family: var(--font-ui);
  font-size: 0.75rem;
  line-height: 1.5;
  color: color-mix(in srgb, var(--bg) 70%, transparent);
  margin-bottom: 10px;
  word-break: keep-all;
}
.brief-box-cta {
  display: block;
  font-family: var(--font-ui);
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--accent);
}
[data-theme="dark"] .brief-box {
  background: var(--bg-2);
  border: 1px solid var(--line);
}
[data-theme="dark"] .brief-box-title { color: var(--ink); }
[data-theme="dark"] .brief-box-desc { color: var(--muted); }

/* ─── Responsive ─── */
@media (max-width: 1023px) {
  .hero-zone { grid-template-columns: 1fr; }
  .hero-main { border-right: none; border-bottom: 1px solid var(--line); }
}
@media (max-width: 767px) {
  .hero-main { padding: 20px 18px 24px; }
  .hero-sidebar { padding: 20px 18px; }
  .lead-story { grid-template-columns: 1fr; gap: 16px; }
  .lead-image { order: -1; }
  .sub-stories { grid-template-columns: 1fr; gap: 18px; }
}
</style>
