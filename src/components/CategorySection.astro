---
import { categoryName, type CategorySlug } from '../lib/categories';
import ArticleCard from './ArticleCard.astro';

interface PostData {
  id: string;
  title: string;
  description: string;
  category: CategorySlug;
  pubDate: Date;
  heroImage?: string;
  author?: string;
  readingTime?: number;
}

interface Props {
  category: CategorySlug;
  posts: PostData[];
  /** 카테고리 전체 글 수 (노출 수와 다르므로 별도 전달) */
  total?: number;
}

const { category, posts, total } = Astro.props;
---
{posts.length > 0 && (
  <section class="cat-section" aria-label={categoryName(category)}>
    <div class:list={['cat-section-header', category]}>
      <h2 class:list={['cat-section-title', category]}>
        <span class="cat-dot" aria-hidden="true"></span>
        {categoryName(category)}
        {total != null && <span class="cat-count">{total}편</span>}
      </h2>
      <a class="cat-more" href={`/category/${category}/`}>
        더 보기
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
    <div class="cat-grid">
      {posts.map((post) => (
        <ArticleCard
          id={post.id}
          title={post.title}
          description={post.description}
          category={post.category}
          pubDate={post.pubDate}
          heroImage={post.heroImage}
          author={post.author}
          readingTime={post.readingTime}
        />
      ))}
    </div>
  </section>
)}

<style>
.cat-section { margin-bottom: 48px; }

.cat-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 2px solid var(--line);
  position: relative;
}
.cat-section-header::after {
  content: '';
  position: absolute;
  left: 0; bottom: -2px;
  width: 56px; height: 2px;
  border-radius: 1px;
}
.cat-section-header::after { background: var(--accent); }

.cat-section-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-serif);
  font-size: 1.25rem;
  font-weight: 700;
  letter-spacing: -0.015em;
  color: var(--ink);
  margin: 0;
}
.cat-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex: none;
  background: var(--accent);
}

.cat-count {
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  color: var(--muted);
  background: var(--line-2);
  padding: 2px 7px;
  border-radius: 999px;
  margin-left: 4px;
}

.cat-more {
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 4px;
  text-decoration: none;
  transition: color .15s;
}
.cat-more:hover { color: var(--accent); text-decoration: none; }

.cat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr); /* 같은 폭에 4개 노출 */
  gap: 16px;
}
@media (max-width: 1023px) { .cat-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 767px)  { .cat-grid { grid-template-columns: 1fr; } }
</style>
