---
import { categoryName, type CategorySlug } from '../lib/categories';

interface Props {
  id: string;
  title: string;
  description: string;
  category: CategorySlug;
  pubDate: Date;
}

const { id, title, description, category, pubDate } = Astro.props;
const dateLabel = pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
---
<div class="featured-wrap">
  <span class="featured-label">1면 톱기사</span>
  <a class="featured-card" href={`/blog/${id}/`}>
    <span class="featured-category">{categoryName(category)}</span>
    <h2 class="featured-title">{title}</h2>
    <p class="featured-desc">{description}</p>
    <time class="featured-date" datetime={pubDate.toISOString()}>{dateLabel}</time>
  </a>
</div>

<style>
  .featured-wrap {
    margin-bottom: 40px;
  }
  .featured-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    background: var(--accent);
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 12px;
  }
  .featured-card {
    display: block;
    padding: 24px 28px;
    border: 1.5px solid var(--accent);
    border-radius: 16px;
    background: var(--accent-soft);
    color: var(--ink);
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }
  .featured-card:hover {
    text-decoration: none;
    transform: translateY(-3px);
    box-shadow: 0 10px 32px rgba(122, 63, 242, 0.18);
    background: var(--accent-soft);
  }
  .featured-category {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .featured-title {
    margin: 0 0 10px;
    font-size: 1.45rem;
    font-weight: 800;
    line-height: 1.3;
    letter-spacing: -0.03em;
    color: var(--ink);
    transition: color 0.15s ease;
  }
  .featured-card:hover .featured-title {
    color: var(--accent);
  }
  .featured-desc {
    margin: 0 0 14px;
    color: var(--muted);
    line-height: 1.65;
    font-size: 0.97rem;
  }
  .featured-date {
    color: var(--muted);
    font-size: 0.83rem;
  }
</style>
