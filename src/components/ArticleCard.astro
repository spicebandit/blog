---
import { categoryName, type CategorySlug } from '../lib/categories';

interface Props {
  id: string;
  title: string;
  description: string;
  category: CategorySlug;
  pubDate: Date;
  heroImage?: string;
  author?: string;
  readingTime?: number;
}

const { id, title, description, category, pubDate, heroImage, author, readingTime } = Astro.props;
const dateLabel = pubDate.toLocaleDateString('ko-KR', { timeZone: 'Asia/Seoul', month: 'long', day: 'numeric' });
---
<a class="article-card" href={`/blog/${id}/`} aria-label={title}>
  <div class:list={['card-thumb', !heroImage && `thumb-${category}`]}>
    {heroImage
      ? <img src={heroImage} alt="" loading="lazy" />
      : <div class="thumb-placeholder" aria-hidden="true"></div>
    }
  </div>
  <div class="card-body">
    <div class="card-meta-top">
      <span class:list={['cat-badge', category]}>{categoryName(category)}</span>
    </div>
    <h3 class="card-headline">{title}</h3>
    <p class="card-desc">{description}</p>
    <div class="card-meta-bottom">
      {author && <span class="author">{author}</span>}
      {author && <span class="sep">·</span>}
      <time datetime={pubDate.toISOString()}>{dateLabel}</time>
      {readingTime && <><span class="sep">·</span><span>{readingTime}분</span></>}
    </div>
  </div>
</a>

<style>
.article-card {
  display: block;
  border: 1px solid var(--line);
  border-radius: var(--radius-lg, 14px);
  overflow: hidden;
  background: var(--bg);
  transition: box-shadow .2s, transform .2s, border-color .2s;
  color: var(--ink);
  text-decoration: none;
}
.article-card:hover {
  box-shadow: var(--shadow-md, 0 4px 16px rgba(0,0,0,.10));
  transform: translateY(-2px);
  border-color: var(--accent);
  text-decoration: none;
}
.card-thumb {
  width: 100%;
  aspect-ratio: 16/9;
  overflow: hidden;
}
.thumb-placeholder {
  width: 100%;
  height: 100%;
}
.card-thumb.thumb-energy   .thumb-placeholder { background: linear-gradient(135deg, #451a03, #92400e, #d97706); }
.card-thumb.thumb-economy  .thumb-placeholder { background: linear-gradient(135deg, #022c22, #065f46, #059669); }
.card-thumb.thumb-ai       .thumb-placeholder { background: linear-gradient(135deg, #1e1b4b, #4c1d95, #7a3ff2); }
.card-thumb.thumb-life     .thumb-placeholder { background: linear-gradient(135deg, #500724, #9d174d, #db2777); }
.card-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

.card-body { padding: 16px; }
.card-meta-top { margin-bottom: 8px; }
.cat-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  padding: 3px 9px;
  border-radius: 999px;
}
.cat-badge.energy  { background: var(--cat-energy-soft, #fef3c7);  color: var(--cat-energy, #d97706); }
.cat-badge.economy { background: var(--cat-economy-soft, #d1fae5); color: var(--cat-economy, #059669); }
.cat-badge.ai      { background: var(--cat-ai-soft, #ede9fe);      color: var(--cat-ai, #7a3ff2); }
.cat-badge.life    { background: var(--cat-life-soft, #fce7f3);    color: var(--cat-life, #db2777); }

.card-headline {
  margin: 0 0 8px;
  font-size: 1.0625rem;
  font-weight: 700;
  line-height: 1.35;
  letter-spacing: -0.035em;
  color: var(--ink);
  word-break: keep-all;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.article-card:hover .card-headline { color: var(--accent); }

.card-desc {
  margin: 0 0 12px;
  font-size: 0.8125rem;
  color: var(--muted);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: keep-all;
}
.card-meta-bottom {
  font-size: 12px;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 6px;
}
.card-meta-bottom .author { font-weight: 600; color: var(--ink-2, var(--muted)); }
.card-meta-bottom .sep { color: var(--line); }
</style>
