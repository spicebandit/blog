---
import type { CollectionEntry } from 'astro:content';
import { categoryName } from '../lib/categories';
import type { CategorySlug } from '../lib/categories';
import { formatDateKRCompact } from '../lib/format';
import AdSlot from './AdSlot.astro';

interface Props {
  recentPosts: CollectionEntry<'blog'>[];
  catPosts:    CollectionEntry<'blog'>[];
  category:    CategorySlug;
}

const { recentPosts, catPosts, category } = Astro.props;
---

<aside class="article-sidebar" aria-label="관련 기사">
  <section class="sb-section">
    <h2 class="sb-heading">최근 기사</h2>
    <ul class="sb-list">
      {recentPosts.map(p => (
        <li class="sb-item">
          <a href={`/blog/${p.id}/`} class="sb-link">
            <span class="sb-title">{p.data.title}</span>
            <span class="sb-meta">
              <span class={`sb-cat cat-${p.data.category}`}>
                {categoryName(p.data.category)}
              </span>
              <time datetime={p.data.pubDate.toISOString()}>
                {formatDateKRCompact(p.data.pubDate)}
              </time>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  {catPosts.length > 0 && (
    <section class="sb-section">
      <h2 class="sb-heading">
        {categoryName(category)}
        <a href={`/category/${category}/`} class="sb-more-link">더보기 →</a>
      </h2>
      <ul class="sb-list">
        {catPosts.map(p => (
          <li class="sb-item">
            <a href={`/blog/${p.id}/`} class="sb-link">
              <span class="sb-title">{p.data.title}</span>
              <span class="sb-meta">
                <time datetime={p.data.pubDate.toISOString()}>
                  {formatDateKRCompact(p.data.pubDate)}
                </time>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {/* 사이드바 하단 광고 (AdSense, 반응형 소형) */}
  <AdSlot position="sidebar" network="adsense" />
</aside>

<style>
  .article-sidebar {
    position: sticky;
    top: 24px; /* 헤더가 비고정이므로 화면 상단 기준 */
    max-height: calc(100vh - 48px);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .article-sidebar::-webkit-scrollbar { display: none; }

  .sb-section { margin-bottom: 28px; }

  .sb-heading {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .sb-more-link {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0;
    text-transform: none;
    transition: opacity 0.15s;
  }
  .sb-more-link:hover { opacity: 0.75; text-decoration: none; }

  .sb-list { list-style: none; margin: 0; padding: 0; }

  .sb-item { border-bottom: 1px solid var(--line-2); }
  .sb-item:last-child { border-bottom: none; }

  .sb-link {
    display: block;
    padding: 10px 8px;
    margin: 0 -8px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--ink);
    transition: background 0.15s, color 0.15s;
  }
  .sb-link:hover {
    background: var(--accent-soft);
    text-decoration: none;
  }
  .sb-link:hover .sb-title { color: var(--accent); }

  .sb-title {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: -0.01em;
    word-break: keep-all;
    transition: color 0.15s;
  }

  .sb-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 5px;
    font-size: 0.75rem;
    color: var(--muted);
  }

  /* 신문형: 배경 없는 레드 캡스 라벨 */
  .sb-cat {
    display: inline-block;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  @media (max-width: 959px) {
    .article-sidebar { display: none; }
  }
</style>
