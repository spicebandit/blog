---
import type { CollectionEntry } from 'astro:content';
import { categoryName } from '../lib/categories';
import type { CategorySlug } from '../lib/categories';

interface Props {
  recentPosts: CollectionEntry<'blog'>[];
  catPosts:    CollectionEntry<'blog'>[];
  category:    CategorySlug;
}

const { recentPosts, catPosts, category } = Astro.props;
---

<aside class="article-sidebar" aria-label="관련 기사">
  <section class="sb-section">
    <h2 class="sb-heading">최근 기사</h2>
    <ul class="sb-list">
      {recentPosts.map(p => (
        <li class="sb-item">
          <a href={`/blog/${p.id}/`} class="sb-link">
            <span class="sb-title">{p.data.title}</span>
            <span class="sb-meta">
              <span class={`sb-cat cat-${p.data.category}`}>
                {categoryName(p.data.category)}
              </span>
              <time datetime={p.data.pubDate.toISOString()}>
                {p.data.pubDate.toLocaleDateString('ko-KR', { timeZone: 'Asia/Seoul', month: 'short', day: 'numeric' })}
              </time>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  {catPosts.length > 0 && (
    <section class="sb-section">
      <h2 class="sb-heading">
        {categoryName(category)}
        <a href={`/category/${category}/`} class="sb-more-link">더보기 →</a>
      </h2>
      <ul class="sb-list">
        {catPosts.map(p => (
          <li class="sb-item">
            <a href={`/blog/${p.id}/`} class="sb-link">
              <span class="sb-title">{p.data.title}</span>
              <span class="sb-meta">
                <time datetime={p.data.pubDate.toISOString()}>
                  {p.data.pubDate.toLocaleDateString('ko-KR', { timeZone: 'Asia/Seoul', month: 'short', day: 'numeric' })}
                </time>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</aside>

<style>
  .article-sidebar {
    position: sticky;
    top: calc(var(--nav-h) + 24px);
    max-height: calc(100vh - var(--nav-h) - 48px);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .article-sidebar::-webkit-scrollbar { display: none; }

  .sb-section { margin-bottom: 28px; }

  .sb-heading {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .sb-more-link {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0;
    text-transform: none;
    transition: opacity 0.15s;
  }
  .sb-more-link:hover { opacity: 0.75; text-decoration: none; }

  .sb-list { list-style: none; margin: 0; padding: 0; }

  .sb-item { border-bottom: 1px solid var(--line-2); }
  .sb-item:last-child { border-bottom: none; }

  .sb-link {
    display: block;
    padding: 10px 8px;
    margin: 0 -8px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--ink);
    transition: background 0.15s, color 0.15s;
  }
  .sb-link:hover {
    background: var(--accent-soft);
    text-decoration: none;
  }
  .sb-link:hover .sb-title { color: var(--accent); }

  .sb-title {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: -0.01em;
    word-break: keep-all;
    transition: color 0.15s;
  }

  .sb-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 5px;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .sb-cat {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 999px;
  }
  .sb-cat.cat-energy  { background: var(--cat-energy-soft);  color: var(--cat-energy); }
  .sb-cat.cat-economy { background: var(--cat-economy-soft); color: var(--cat-economy); }
  .sb-cat.cat-ai      { background: var(--cat-ai-soft);      color: var(--cat-ai); }
  .sb-cat.cat-life    { background: var(--cat-life-soft);    color: var(--cat-life); }

  @media (max-width: 959px) {
    .article-sidebar { display: none; }
  }
</style>
