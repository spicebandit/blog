---
/**
 * 자체 댓글 위젯 (Cusdis 대체, 정적 사이트 + Vercel 서버함수).
 *
 * - 공개 댓글: 누구나 작성 즉시 노출. (스팸 대응은 추후)
 * - 편집자(소유자) 댓글: 브라우저 localStorage('baseload_author_key')에 비밀키가 있으면
 *   그 키를 함께 보내 서버가 소유자로 판정 → 비공개 편집 메모로 저장(화면에 안 뜸).
 * - 편집자 답글(author_reply)은 목록에 '편집자' 배지로 노출된다.
 *
 * slug = pageId (글 식별자). 영문판은 en- 접두가 붙어 자연히 분리된다.
 */
interface Props {
  pageId: string;
  pageTitle: string;
}
const { pageId } = Astro.props;
---
<section class="comments">
  <h2>댓글</h2>
  <div class="cbox" data-slug={pageId}>
    <p class="cnote" data-role="owner-indicator" hidden>✍️ 편집자 모드 — 이 댓글은 공개되지 않고 편집자에게만 전달됩니다.</p>
    <ul class="clist" data-role="list"><li class="cempty" data-role="empty">불러오는 중…</li></ul>
    <form class="cform" data-role="form" autocomplete="off">
      <div class="crow">
        <input type="text" name="author" maxlength="40" placeholder="이름(선택)" data-role="author" />
      </div>
      <textarea name="body" maxlength="4000" rows="3" placeholder="댓글을 남겨주세요" required data-role="body"></textarea>
      <!-- 스팸 봇 유인용 허니팟(사람에겐 안 보임) -->
      <input type="text" name="website" tabindex="-1" autocomplete="off" class="choney" aria-hidden="true" />
      <div class="cactions">
        <span class="cmsg" data-role="msg" role="status"></span>
        <button type="submit" data-role="submit">등록</button>
      </div>
    </form>
  </div>
</section>

<script is:inline>
  (function () {
    var box = document.querySelector('.cbox');
    if (!box) return;
    var slug = box.getAttribute('data-slug');
    var listEl = box.querySelector('[data-role="list"]');
    var form = box.querySelector('[data-role="form"]');
    var authorEl = box.querySelector('[data-role="author"]');
    var bodyEl = box.querySelector('[data-role="body"]');
    var honey = box.querySelector('.choney');
    var msgEl = box.querySelector('[data-role="msg"]');
    var submitEl = box.querySelector('[data-role="submit"]');
    var ownerInd = box.querySelector('[data-role="owner-indicator"]');
    var ownerKey = '';
    try { ownerKey = localStorage.getItem('baseload_author_key') || ''; } catch (e) {}
    if (ownerKey && ownerInd) ownerInd.hidden = false;

    function fmt(ts) {
      try {
        var d = new Date(ts);
        return d.toLocaleDateString('ko-KR', { timeZone: 'Asia/Seoul', year: '2-digit', month: '2-digit', day: '2-digit' }).replace(/\.$/, '')
          + ' ' + d.toLocaleTimeString('ko-KR', { timeZone: 'Asia/Seoul', hour: '2-digit', minute: '2-digit', hour12: false });
      } catch (e) { return ''; }
    }
    // XSS 안전: 텍스트는 textContent로만 넣는다
    function node(comment) {
      var li = document.createElement('li');
      li.className = 'citem' + (comment.role === 'author_reply' ? ' creply' : '');
      var head = document.createElement('div');
      head.className = 'chead';
      var name = document.createElement('span');
      name.className = 'cauthor';
      name.textContent = comment.author || '익명';
      head.appendChild(name);
      if (comment.role === 'author_reply') {
        var badge = document.createElement('span');
        badge.className = 'cbadge';
        badge.textContent = '편집자';
        head.appendChild(badge);
      }
      var time = document.createElement('span');
      time.className = 'ctime';
      time.textContent = fmt(comment.created_at);
      head.appendChild(time);
      var body = document.createElement('div');
      body.className = 'cbody';
      body.textContent = comment.body || '';
      li.appendChild(head);
      li.appendChild(body);
      return li;
    }
    function render(comments) {
      listEl.innerHTML = '';
      if (!comments || !comments.length) {
        var e = document.createElement('li');
        e.className = 'cempty';
        e.textContent = '첫 댓글을 남겨보세요.';
        listEl.appendChild(e);
        return;
      }
      // 부모→답글(author_reply) 순으로 그룹핑
      var byId = {}, tops = [];
      comments.forEach(function (c) { byId[c.id] = c; c._children = []; });
      comments.forEach(function (c) {
        if (c.parent_id && byId[c.parent_id]) byId[c.parent_id]._children.push(c);
        else tops.push(c);
      });
      tops.forEach(function (c) {
        listEl.appendChild(node(c));
        (c._children || []).forEach(function (ch) {
          var n = node(ch); n.classList.add('cchild'); listEl.appendChild(n);
        });
      });
    }
    function load() {
      fetch('/api/comments?slug=' + encodeURIComponent(slug))
        .then(function (r) { return r.json(); })
        .then(function (d) { render(d.comments || []); })
        .catch(function () {
          listEl.innerHTML = '';
          var e = document.createElement('li'); e.className = 'cempty';
          e.textContent = '댓글을 불러오지 못했습니다.'; listEl.appendChild(e);
        });
    }

    form.addEventListener('submit', function (ev) {
      ev.preventDefault();
      if (honey && honey.value) return; // 봇
      var body = (bodyEl.value || '').trim();
      if (body.length < 2) { msg('내용을 입력해주세요.', true); return; }
      submitEl.disabled = true; msg('등록 중…', false);
      fetch('/api/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug: slug, author: (authorEl.value || '').trim(), body: body, ownerKey: ownerKey }),
      })
        .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
        .then(function (res) {
          submitEl.disabled = false;
          if (!res.ok || res.d.error) { msg(res.d.error || '등록 실패', true); return; }
          bodyEl.value = '';
          if (res.d.owner) { msg('편집자에게 전달되었습니다(비공개).', false); }
          else { msg('등록되었습니다.', false); load(); }
          setTimeout(function () { msg('', false); }, 4000);
        })
        .catch(function () { submitEl.disabled = false; msg('네트워크 오류', true); });
    });
    function msg(t, isErr) { msgEl.textContent = t; msgEl.style.color = isErr ? 'var(--accent)' : 'var(--muted)'; }

    load();
  })();
</script>

<style>
  .comments {
    margin-top: 64px;
    padding-top: 28px;
    border-top: 2px solid var(--ink);
  }
  .comments h2 {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 18px;
  }
  .cbox {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 18px;
  }
  .cnote {
    margin: 0 0 12px;
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 600;
  }
  .clist { list-style: none; margin: 0 0 16px; padding: 0; }
  .cempty { color: var(--muted); font-size: 0.9rem; padding: 4px 0; }
  .citem {
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
  }
  .citem:last-child { border-bottom: none; }
  .cchild { margin-left: 20px; border-left: 2px solid var(--line); padding-left: 12px; }
  .chead { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
  .cauthor { font-weight: 700; color: var(--ink); font-size: 0.9rem; }
  .cbadge {
    background: var(--accent); color: #fff;
    font-size: 0.68rem; font-weight: 700;
    padding: 1px 6px; border-radius: 4px;
  }
  .ctime { color: var(--muted); font-size: 0.78rem; margin-left: auto; }
  .cbody { color: var(--ink); font-size: 0.95rem; line-height: 1.6; white-space: pre-wrap; word-break: break-word; }
  .cform { display: flex; flex-direction: column; gap: 8px; }
  .crow { display: flex; gap: 8px; }
  .cform input[type="text"]:not(.choney), .cform textarea {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--ink);
    padding: 8px 10px;
    font: inherit;
    width: 100%;
    box-sizing: border-box;
  }
  .cform input:focus, .cform textarea:focus {
    border-color: var(--accent); outline: none;
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 20%, transparent);
  }
  .cform textarea { resize: vertical; min-height: 60px; }
  .choney { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .cactions { display: flex; align-items: center; justify-content: flex-end; gap: 12px; }
  .cmsg { font-size: 0.82rem; color: var(--muted); margin-right: auto; }
  .cform button {
    background: var(--accent); color: #fff; border: none;
    border-radius: 8px; font-weight: 600; padding: 8px 18px; cursor: pointer;
  }
  .cform button:hover { filter: brightness(0.94); }
  .cform button:disabled { opacity: 0.6; cursor: default; }
</style>
