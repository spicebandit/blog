---
/**
 * AdSlot — Google AdSense + Kakao AdFit 광고 슬롯
 *
 * 빌드 시 환경변수 확인:
 *   PUBLIC_ADSENSE_PUBLISHER_ID   e.g. ca-pub-1234567890123456
 *   PUBLIC_ADSENSE_SLOT_HEADER    header 슬롯 ID (10자리)
 *   PUBLIC_ADSENSE_SLOT_IN_ARTICLE
 *   PUBLIC_ADSENSE_SLOT_BOTTOM
 *   PUBLIC_ADSENSE_SLOT_SIDEBAR
 *   PUBLIC_ADFIT_UNIT_HEADER      e.g. DAN-XXXXXXXXXX (PC 728×90)
 *   PUBLIC_ADFIT_UNIT_HEADER_M    e.g. DAN-XXXXXXXXXX (모바일 320×100)
 *   PUBLIC_ADFIT_UNIT_IN_ARTICLE
 *   PUBLIC_ADFIT_UNIT_BOTTOM
 *
 * 환경변수가 없으면 DEV에서만 플레이스홀더 표시, 프로덕션에서는 아무것도 렌더링하지 않음.
 */

type AdPosition = 'header' | 'in-article' | 'bottom' | 'sidebar';
type AdNetwork = 'auto' | 'adfit' | 'adsense';

interface Props {
  position: AdPosition;
  network?: AdNetwork;
  class?: string;
}

const { position, network = 'auto', class: className } = Astro.props;

const PUB_ID = import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID ?? '';

const ADSENSE_SLOTS: Record<AdPosition, string> = {
  'header':     import.meta.env.PUBLIC_ADSENSE_SLOT_HEADER     ?? '',
  'in-article': import.meta.env.PUBLIC_ADSENSE_SLOT_IN_ARTICLE ?? '',
  'bottom':     import.meta.env.PUBLIC_ADSENSE_SLOT_BOTTOM     ?? '',
  'sidebar':    import.meta.env.PUBLIC_ADSENSE_SLOT_SIDEBAR     ?? '',
};

const ADFIT_UNITS: Record<AdPosition, string> = {
  'header':     import.meta.env.PUBLIC_ADFIT_UNIT_HEADER     ?? '',
  'in-article': import.meta.env.PUBLIC_ADFIT_UNIT_IN_ARTICLE ?? '',
  'bottom':     import.meta.env.PUBLIC_ADFIT_UNIT_BOTTOM     ?? '',
  // 사이드바: 미사용 중인 모바일 헤더 유닛(320×50)을 재활용 — bottom 유닛과 한 페이지 중복 방지
  'sidebar':    import.meta.env.PUBLIC_ADFIT_UNIT_HEADER_M
             ?? import.meta.env.PUBLIC_ADFIT_UNIT_BOTTOM ?? '',
};
const ADFIT_HEADER_M = import.meta.env.PUBLIC_ADFIT_UNIT_HEADER_M ?? '';

const slotId  = ADSENSE_SLOTS[position];
const adfitId = ADFIT_UNITS[position];

const hasAdsense = !!(PUB_ID && slotId);
// 헤더 위치는 PC 단위(adfitId) 또는 모바일 단위(ADFIT_HEADER_M) 중 하나만 있어도 렌더
const hasAdfit   = position === 'header' ? !!(adfitId || ADFIT_HEADER_M) : !!adfitId;
const isInArticle = position === 'in-article';
const isDev      = import.meta.env.DEV;

// network prop으로 위치별 광고망 강제 지정 가능 (기본 'auto' = AdFit 우선)
//  - 'adfit'   : AdFit만 노출
//  - 'adsense' : AdSense만 노출
//  - 'auto'    : AdFit 단위가 있으면 AdFit, 없으면 AdSense (AdSense 미승인 기간 빈 칸 방지)
const showAdfit =
  network === 'adsense' ? false :
  network === 'adfit'   ? hasAdfit :
  hasAdfit;
const showAdsense =
  network === 'adfit'   ? false :
  network === 'adsense' ? hasAdsense :
  (!hasAdfit && hasAdsense);
const showAd = showAdfit || showAdsense;

// AdFit dimensions per position (PC / mobile handled via CSS)
const ADFIT_DIM: Record<AdPosition, { w: number; h: number }> = {
  'header':     { w: 728, h: 90 },
  'in-article': { w: 320, h: 100 },
  'bottom':     { w: 320, h: 50 },
  'sidebar':    { w: 320, h: 50 }, /* HEADER_M 유닛 크기와 일치해야 함 */
};
const adfitDim = ADFIT_DIM[position];
---

{showAd ? (
  <div class:list={['ad-slot', `ad-${position}`, className]}>
    <span class="ad-label">광고</span>

    {showAdsense && (
      isInArticle ? (
        <ins class="adsbygoogle"
          style="display:block; text-align:center;"
          data-ad-layout="in-article"
          data-ad-format="fluid"
          data-ad-client={PUB_ID}
          data-ad-slot={slotId}>
        </ins>
        <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      ) : (
        <ins class="adsbygoogle"
          style="display:block"
          data-ad-client={PUB_ID}
          data-ad-slot={slotId}
          data-ad-format="auto"
          data-full-width-responsive="true">
        </ins>
        <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      )
    )}

    {/* AdFit: 헤더 광고 (PC 728×90 / 모바일 320×50) */}
    {showAdfit && position === 'header' && (
      <>
        {adfitId && (
          <ins class="kakao_ad_area adfit-pc" style="display:none;"
            data-ad-unit={adfitId}
            data-ad-width="728"
            data-ad-height="90">
          </ins>
        )}
        {ADFIT_HEADER_M && (
          <ins class="kakao_ad_area adfit-mobile" style="display:none;"
            data-ad-unit={ADFIT_HEADER_M}
            data-ad-width="320"
            data-ad-height="50">
          </ins>
        )}
      </>
    )}
    {showAdfit && position !== 'header' && (
      <ins class="kakao_ad_area" style="display:none;"
        data-ad-unit={adfitId}
        data-ad-width={adfitDim.w}
        data-ad-height={adfitDim.h}>
      </ins>
    )}
  </div>
) : isDev ? (
  <div class:list={['ad-slot', 'ad-placeholder', `ad-${position}`, className]}>
    <span class="ad-label">광고 슬롯 [{position}]</span>
    <div class="ad-hint">
      ENV 미설정 — <code>PUBLIC_ADSENSE_PUBLISHER_ID</code> 등 필요
    </div>
  </div>
) : null}

<style>
  /* 신문 광고란 스타일: 지면색 박스+괘선으로 감싸 흰 광고 소재가 튀지 않게 */
  .ad-slot {
    margin: 2em 0;
    text-align: center;
    overflow: hidden;
    background: var(--bg-2);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 10px 12px 14px;
  }
  .ad-label {
    display: block;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }
  /* AdSense가 광고를 채우지 않으면(unfilled) 슬롯 전체 숨김 */
  .ad-slot:has(ins.adsbygoogle[data-ad-status="unfilled"]) {
    display: none;
  }

  /* Placeholder (DEV only) */
  .ad-placeholder {
    background: var(--ad-bg, #f3f4f6);
    border: 1px dashed var(--line);
    border-radius: var(--radius-lg, 14px);
    padding: 20px;
    min-height: 90px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .ad-hint {
    font-size: 0.78rem;
    color: var(--muted);
  }
  .ad-hint code {
    font-size: 0.75rem;
    background: var(--line-2);
    padding: 2px 6px;
    border-radius: 4px;
  }

  /* AdFit 반응형: 헤더는 PC/모바일 분리 */
  .adfit-mobile { display: none !important; }
  @media (max-width: 767px) {
    .adfit-pc     { display: none !important; }
    .adfit-mobile { display: block !important; }
  }

  /* 사이드바 하단 광고: 위 목록과 간격만 주고 정적 배치 (aside가 이미 sticky) */
  .ad-sidebar {
    margin-top: 8px;
    padding-top: 20px;
    border-top: 2px solid var(--line);
  }
</style>
